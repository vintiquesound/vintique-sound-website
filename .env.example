# Email sending for "Request This Package"
#
# Option A (recommended): SMTP via nodemailer
# 1) pnpm add nodemailer
# 2) Fill these values
#
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Full Name <email@email.com>"

# Where package requests should be delivered
REQUEST_PACKAGE_TO=email@email.com

# Set to 1 to test locally without sending any emails.
# Requests will be logged on the server, and the UI shows a preview.
EMAIL_DRY_RUN=1
