# ----------------------------------------------------------------------------
# Vintique Sound - Environment Variables (public-safe example)
# ----------------------------------------------------------------------------
# This file is intended to be committed to Git.
# Do NOT put real secrets here. Copy to `.env` for local development and
# set real values in your hosting provider's secret/environment settings.
#
# Recommended workflow:
# 1) cp .env.example .env
# 2) Replace placeholder values in .env
# 3) Keep .env uncommitted
#
# Boolean convention in this project:
# - true values are treated as: "1" or "true"
# - anything else is treated as false
# ----------------------------------------------------------------------------

# =========================
# Email / SMTP (server-only)
# =========================
# Required for sending contact/request emails.
SMTP_HOST=smtp.example.com # (examples: smtp.gmail.com, smtp.zoho.com, smtp.mailgun.org)
SMTP_PORT=587 # or 465 with SMTP_SECURE=true (587 for STARTTLS, 465 for SSL)
SMTP_USER=mailer@example.com
SMTP_PASS=replace-with-real-password
# "From" address for outgoing mail.
# If empty, API falls back to the business request email.
# Example: Vintique Sound <hello@example.com>.
SMTP_FROM="Vintique Sound <mailer@example.com>"

# Optional. If blank, code auto-enables secure mode when SMTP_PORT=465.
# Set explicitly to true/false if you want to force behavior.
SMTP_SECURE=false

# Optional. Enables dry-run mode (no outbound email). Useful in local dev.
EMAIL_DRY_RUN=false

# Optional. Enables debug behavior for email diagnostics endpoints.
EMAIL_DEBUG_ENABLED=false

# Optional but recommended if EMAIL_DEBUG_ENABLED=true.
# Used to protect debug endpoints from unauthenticated probing.
EMAIL_DEBUG_TOKEN=replace-with-random-long-token

# =========================
# Public runtime config
# =========================
# Optional. Google Tag Manager container ID.
# Prefer this PUBLIC_ variable for front-end analytics configuration.
PUBLIC_GTM_ID=GTM-XXXXXXX

# Optional. Live CSV source used by the clients-and-credits page.
# If unset, the page falls back to embedded sample data.
CLIENTS_CREDITS_CSV_URL=https://example.com/clients-and-credits.csv
