---
// Third party libraries
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";

// Local content and assets
import { SITE_TITLE } from "@/consts";
import { navMenuGroups } from "@/lib/navigation";
import { socials } from "@/lib/socials";
import logo from "@/assets/vintique_sound_logo-letters_only.png";

// Const definitions
const today = new Date();
---

<footer class="py-8 px-4 bg-muted border-t border-border text-(--text)">
  <div class="mx-auto w-full max-w-6xl px-4 sm:px-6 lg:px-8">
    <div
      class="grid gap-10 md:gap-6 lg:gap-10 items-start md:grid-cols-2 lg:grid-cols-[repeat(var(--footer-column-count),minmax(0,1fr))]"
      style={`--footer-column-count: ${navMenuGroups.length + 1};`}
    >
      <div class="flex flex-col gap-4 items-start text-left">
        <a
          href="/"
          aria-label={SITE_TITLE}
          class="inline-block shrink-0 no-underline text-(--text)"
        >
          <Image
            src={logo}
            alt={SITE_TITLE + " logo"}
            width={91}
            height={40}
            class="block h-10 w-auto shrink-0"
          />
        </a>
        <p class="m-0 text-left text-muted-foreground text-sm">
          Professional audio services, education, and products for producers and engineers worldwide.
        </p>
      </div>

      {navMenuGroups.map((group) => (
        <div
          class="flex flex-col gap-3 items-start text-left"
          data-nav-group={group.title}
        >
          <div class="font-semibold text-sm text-foreground tracking-wide">
            {group.title}
          </div>
          <div class="flex flex-col gap-2">
            {group.children.map((item) => (
              <a
                href={item.href}
                class="no-underline text-muted-foreground hover:text-accent text-sm transition-colors"
                data-nav-item={item.href}
              >
                {item.label}
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>

  <div class="flex justify-center mb-2">
    <hr class="w-11/12 rounded-full border border-muted-foreground/12 my-4" />
  </div>

  <div class="text-center text-muted-foreground">
    &copy; 2011 - {today.getFullYear()} Vintique Sound. All rights reserved.
    <div class="flex justify-center gap-4 mt-4 text-accent">
      {socials.map(({ name, url, iconName, label }) => (
        <a
          href={url}
          target="_blank"
          class="no-underline text-accent hover:text-secondary"
          aria-label={name}
        >
          <span class="sr-only">{label}</span>
          <Icon name={iconName} size={32} />
        </a>
      ))}
    </div>
  </div>
</footer>
