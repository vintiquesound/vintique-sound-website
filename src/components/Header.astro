---
// Local components
import HeaderNavMenu from "./HeaderNavMenu";
import ThemeToggle from "./ThemeToggle.astro";
import CurrencySelector from "./CurrencySelector.astro";
import HeaderLink from "./HeaderLink.astro";

// Third party libraries
import { Image } from "astro:assets";

// Local content and assets
import { SITE_TITLE } from "@/consts";
import { navMenuGroups } from "@/lib/navigation";
import logo from "@/assets/vintique_sound_logo-letters_only.png";

// Const definitions
const pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, "")
const mobileLinkBase =
  "block w-full py-3 px-4 text-base text-(--text) hover:text-accent no-underline transition-colors"
---

<header class="sticky top-0 z-50 border-b border-border isolate">
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 -z-10 bg-background backdrop-blur-lg supports-backdrop-filter:bg-background/85"
  ></div>
  <div class="mx-auto w-full max-w-6xl px-4 sm:px-6 lg:px-8">
    <nav class="flex items-center justify-between">
      <a href="/" aria-label={SITE_TITLE} class="inline-block shrink-0 no-underline text-(--text)">
        <Image src={logo} alt={SITE_TITLE + " logo"} width={91} height={40} class="block h-10 w-auto shrink-0" />
      </a>

      <!-- Desktop nav menu -->
      <div class="hidden md:flex flex-1 items-center justify-center">
        <HeaderNavMenu client:load pathname={pathname} />
      </div>

      <!-- Hamburger menu, only shown on mobile -->
      <div class="flex items-center gap-2 shrink-0">
        <button
          type="button"
          class="md:hidden inline-flex items-center justify-center h-10 w-10 rounded-md border border-border text-(--text) hover:text-accent transition-colors"
          aria-label="Open menu"
          aria-expanded="false"
          aria-controls="mobile-nav"
          data-mobile-menu-button
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-5 w-5"
            aria-hidden="true"
          >
            <line x1="4" y1="6" x2="20" y2="6" />
            <line x1="4" y1="12" x2="20" y2="12" />
            <line x1="4" y1="18" x2="20" y2="18" />
          </svg>
        </button>

        <CurrencySelector />
        <ThemeToggle />
      </div>
    </nav>

    <!-- Mobile nav menu, when hamburger menu is open -->
    <div
      id="mobile-nav"
      class="md:hidden border-t border-border"
      hidden
      style="max-height: 60vh; overflow-y: auto;"
    >
      <nav class="flex flex-col py-2">
        {navMenuGroups.map((group, idx) => (
          <div class="contents" data-nav-group={group.title}>
            <div
              class={`px-4 ${idx === 0 ? "pt-2" : "pt-4"} pb-1 text-sm text-muted-foreground`}
            >
              {group.title}
            </div>
            {group.children.map((item) => (
              <HeaderLink href={item.href} class={mobileLinkBase} data-nav-href={item.href}>
                {item.label}
              </HeaderLink>
            ))}
          </div>
        ))}
      </nav>
    </div>
  </div>
</header>

<script type="module">
  const button = document.querySelector("[data-mobile-menu-button]");
  const panel = document.getElementById("mobile-nav");

  const normalizePath = (value) => value.replace(/\/$/, "") || "/";
  const normalizeHash = (value) => value.replace(/^#/, "").trim().toLowerCase();
  const getSearchGroup = (search) => new URLSearchParams(search).get("group")?.trim().toLowerCase() ?? "";
  const navQueryScopes = {
    audio: ["audio", "audio-services", "mixing-and-mastering", "audio-editing", "audio-repair"],
    training: ["training", "education", "one-on-one-training", "project-feedback"],
  };
  const navHashScopes = {
    "audio-services": ["audio-services", "mixing-and-mastering", "audio-editing", "audio-repair"],
    training: ["training", "education", "one-on-one-training", "project-feedback"],
  };

  const isNavItemActive = (pathname, hash, search, href) => {
    if (!href.startsWith("/")) return false;

    const hrefPath = normalizePath(href.split(/[?#]/, 1)[0] ?? href);
    const hrefHash = href.includes("#") ? normalizeHash(href.split("#")[1] ?? "") : "";
    const normalizedPath = normalizePath(pathname);
    const searchGroup = getSearchGroup(search);
    const subpath = normalizedPath.match(/[^/]+/g);
    const pathMatches = hrefPath === normalizedPath || hrefPath === "/" + (subpath?.[0] || "");

    if (!pathMatches) return false;
    if (!hrefHash) return true;
    if (hash) return (navHashScopes[hrefHash] ?? [hrefHash]).includes(hash);
    if (searchGroup) return (navQueryScopes[searchGroup] ?? [searchGroup]).includes(hrefHash);

    return true;
  };

  const syncMobileNavActiveState = () => {
    if (!panel) return;

    const currentPath = window.location.pathname;
    const currentHash = normalizeHash(window.location.hash);
    const currentSearch = window.location.search;

    panel.querySelectorAll("[data-nav-href]").forEach((link) => {
      if (!(link instanceof HTMLAnchorElement)) return;

      const href = link.dataset.navHref ?? "";
      const active = isNavItemActive(currentPath, currentHash, currentSearch, href);

      link.classList.toggle("font-bold", active);
      link.classList.toggle("underline", active);
    });
  };

  if (button instanceof HTMLButtonElement && panel) {
    const setMenuOpen = (open) => {
      panel.hidden = !open;
      button.setAttribute("aria-expanded", String(open));
      button.setAttribute("aria-label", open ? "Close menu" : "Open menu");
    };

    setMenuOpen(false);
    syncMobileNavActiveState();

    button.addEventListener("click", () => {
      setMenuOpen(panel.hidden);
    });

    window.addEventListener("hashchange", syncMobileNavActiveState);

    document.addEventListener("keydown", (event) => {
      if (event.key !== "Escape") return;
      if (panel.hidden) return;
      setMenuOpen(false);
      button.focus();
    });

    window.addEventListener("resize", () => {
      if (window.matchMedia("(min-width: 768px)").matches) setMenuOpen(false);
    });
  }
</script>
