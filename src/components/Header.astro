---
import { SITE_TITLE } from "../consts";
import HeaderLink from "./HeaderLink.astro";
import ThemeToggle from "./ThemeToggle.astro";
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<div class="menu-item has-submenu">
				<span class="parent-link" tabindex="0">Services</span>
				<div class="submenu">
					<HeaderLink href="/mixing-mastering">Mixing & Mastering</HeaderLink>
					<HeaderLink href="/editing-repairs">Audio Editing</HeaderLink>
					<HeaderLink href="/editing-repairs">Audio Restoration</HeaderLink>
				</div>
			</div>
			<div class="menu-item has-submenu">
        <span class="parent-link" tabindex="1">Education</span>
				<div class="submenu">
          <HeaderLink href="/blog">Blog</HeaderLink>
					<HeaderLink href="/tutorial-videos">Tutorial Videos</HeaderLink>
				</div>
			</div>
			<div class="menu-item has-submenu">
        <span class="parent-link" tabindex="2">Digital Products</span>
				<div class="submenu">
          <HeaderLink href="/plugins">Plugins</HeaderLink>
          <HeaderLink href="/samples-loops">Samples & Loops</HeaderLink>
				</div>
			</div>
			<HeaderLink href="/studio">Studio</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
			<HeaderLink href="/contact">Contact</HeaderLink>
		</div>
    <ThemeToggle />
	</nav>
</header>
<style>
  header {
    margin: 0;
    padding: 0 1em;
    background: var(--surface);
    box-shadow: var(--shadow-1);
  }

  h2 {
    margin: 0;
    font-size: 1em;
  }

  h2 a,
  h2 a.active {
    text-decoration: none;
    color: var(--text);
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  nav a {
    padding: 1em 0.5em;
    color: var(--text);
    border-bottom: 4px solid transparent;
    text-decoration: none;
  }

  nav a.active {
    text-decoration: none;
    border-bottom-color: var(--accent);
  }

  .internal-links {
    display: flex;
    gap: 0.5em;
  }

  .menu-item {
    position: relative;
  }

  .has-submenu .submenu {
    display: none;
    position: absolute;
    left: 0;
    top: 100%;
    background: var(--surface);
    border: 1px solid var(--border);
    box-shadow: var(--shadow-1);
    z-index: 10;
    min-width: 180px;
    flex-direction: column;
  }

  .has-submenu:hover .submenu,
  .has-submenu:focus-within .submenu {
    display: flex;
  }

  .parent-link {
    cursor: pointer;
    padding: 1em 0.5em;
    color: var(--text);
    border-bottom: 4px solid transparent;
    text-decoration: none;
    display: inline-block;
  }

  @media (max-width: 720px) {
    .social-links {
      display: none;
    }
    .has-submenu .submenu {
      position: static;
      box-shadow: none;
      min-width: unset;
    }
  }
</style>
