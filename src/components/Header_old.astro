---
import { SITE_TITLE } from "../consts";
import { Image } from "astro:assets";
import HeaderLink from "./HeaderLink.astro";
import ThemeToggle from "./ThemeToggle.astro";

import logo from "../assets/vintique_sound_logo-letters_only.png";

const navLinkBase = "inline-block py-4 px-2 text-sm lg:text-base text-[var(--text)] hover:text-[var(--accent)] border-b-4 border-transparent no-underline transition-colors [&.active]:border-[var(--accent)]";
const mobileLinkBase = "block w-full py-3 px-4 text-base text-[var(--text)] hover:text-[var(--accent)] no-underline transition-colors";
---

<header class="sticky top-0 z-50 border-b border-border bg-background/95 backdrop-blur-lg supports-backdrop-filter:bg-background/80">
  <div class="mx-auto w-full max-w-6xl px-4 sm:px-6 lg:px-8">
    <nav class="flex items-center justify-between">
      <a href="/" aria-label={SITE_TITLE} class="inline-block shrink-0 no-underline text-[var(--text)]">
        <Image
          src={logo}
          alt={SITE_TITLE + ' logo'}
          width={91}
          height={40}
          class="block h-10 w-auto shrink-0"
        />
      </a>

      <div class="hidden md:flex items-center gap-2 lg:gap-3">
      <div class="relative group/menu-item">
        <span class={`cursor-pointer inline-block ${navLinkBase}`} tabindex="0">Services</span>
        <div
          class="hidden flex-col bg-[var(--surface)] border border-[var(--border)] shadow-[var(--shadow-1)] z-10 group-hover/menu-item:flex group-focus-within/menu-item:flex md:absolute md:left-0 md:top-full md:min-w-[180px] md:shadow-[var(--shadow-1)]"
        >
          <HeaderLink href="/mixing-mastering" class={navLinkBase}>Mixing & Mastering</HeaderLink>
          <HeaderLink href="/editing-repairs" class={navLinkBase}>Audio Editing</HeaderLink>
          <HeaderLink href="/editing-repairs" class={navLinkBase}>Audio Restoration</HeaderLink>
        </div>
      </div>
      <div class="relative group/menu-item">
        <span class={`cursor-pointer inline-block ${navLinkBase}`} tabindex="1">Education</span>
        <div
          class="hidden flex-col bg-[var(--surface)] border border-[var(--border)] shadow-[var(--shadow-1)] z-10 group-hover/menu-item:flex group-focus-within/menu-item:flex md:absolute md:left-0 md:top-full md:min-w-[180px] md:shadow-[var(--shadow-1)]"
        >
          <HeaderLink href="/tutorial-videos" class={navLinkBase}>YouTube Videos</HeaderLink>
          <HeaderLink href="/tutorial-videos" class={navLinkBase}>Tutorial Videos</HeaderLink>
        </div>
      </div>
      <div class="relative group/menu-item">
        <span class={`cursor-pointer inline-block ${navLinkBase}`} tabindex="2">Digital Products</span>
        <div
          class="hidden flex-col bg-[var(--surface)] border border-[var(--border)] shadow-[var(--shadow-1)] z-10 group-hover/menu-item:flex group-focus-within/menu-item:flex md:absolute md:left-0 md:top-full md:min-w-[180px] md:shadow-[var(--shadow-1)]"
        >
          <HeaderLink href="/plugins" class={navLinkBase}>Plugins</HeaderLink>
          <HeaderLink href="/samples-loops" class={navLinkBase}>Samples & Loops</HeaderLink>
        </div>
      </div>
      <HeaderLink href="/studio" class={navLinkBase}>Studio</HeaderLink>
      <HeaderLink href="/blog" class={navLinkBase}>Blog</HeaderLink>
      <HeaderLink href="/about" class={navLinkBase}>About</HeaderLink>
      <HeaderLink href="/contact" class={navLinkBase}>Contact</HeaderLink>
    </div>

      <div class="flex items-center gap-2 shrink-0">
        <button
          type="button"
          class="md:hidden inline-flex items-center justify-center h-10 w-10 rounded-md border border-[var(--border)] text-[var(--text)] hover:text-[var(--accent)] transition-colors"
          aria-label="Open menu"
          aria-expanded="false"
          aria-controls="mobile-nav"
          data-mobile-menu-button
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5" aria-hidden="true">
            <line x1="4" y1="6" x2="20" y2="6" />
            <line x1="4" y1="12" x2="20" y2="12" />
            <line x1="4" y1="18" x2="20" y2="18" />
          </svg>
        </button>

        <ThemeToggle />
      </div>
    </nav>

    <div id="mobile-nav" class="md:hidden border-t border-[var(--border)]" hidden>
      <nav class="flex flex-col py-2">
        <div class="px-4 pt-2 pb-1 text-sm text-[var(--muted)]">Services</div>
        <HeaderLink href="/mixing-mastering" class={mobileLinkBase}>Mixing & Mastering</HeaderLink>
        <HeaderLink href="/editing-repairs" class={mobileLinkBase}>Audio Editing</HeaderLink>
        <HeaderLink href="/editing-repairs" class={mobileLinkBase}>Audio Restoration</HeaderLink>

        <div class="px-4 pt-4 pb-1 text-sm text-[var(--muted)]">Education</div>
        <HeaderLink href="/tutorial-videos" class={mobileLinkBase}>YouTube Videos</HeaderLink>
        <HeaderLink href="/tutorial-videos" class={mobileLinkBase}>Tutorial Videos</HeaderLink>

        <div class="px-4 pt-4 pb-1 text-sm text-[var(--muted)]">Digital Products</div>
        <HeaderLink href="/plugins" class={mobileLinkBase}>Plugins</HeaderLink>
        <HeaderLink href="/samples-loops" class={mobileLinkBase}>Samples & Loops</HeaderLink>

        <div class="mt-2">
          <HeaderLink href="/studio" class={mobileLinkBase}>Studio</HeaderLink>
          <HeaderLink href="/blog" class={mobileLinkBase}>Blog</HeaderLink>
          <HeaderLink href="/about" class={mobileLinkBase}>About</HeaderLink>
          <HeaderLink href="/contact" class={mobileLinkBase}>Contact</HeaderLink>
        </div>
      </nav>
    </div>
  </div>
</header>

<script type="module">
  const button = document.querySelector('[data-mobile-menu-button]');
  const panel = document.getElementById('mobile-nav');

  if (button instanceof HTMLButtonElement && panel) {
    const setOpen = (open) => {
      panel.hidden = !open;
      button.setAttribute('aria-expanded', String(open));
    };

    setOpen(false);

    button.addEventListener('click', () => {
      setOpen(panel.hidden);
    });

    // Close menu on resize up to desktop
    window.addEventListener('resize', () => {
      if (window.matchMedia('(min-width: 768px)').matches) setOpen(false);
    });
  }
</script>
