---
// Astro components
import { submitContact } from "@/actions/contact";

// Local UI components
import Button from "@/components/ui/Button.astro";
import Input from "@/components/ui/input.astro";
import Textarea from "@/components/ui/text-area.astro";
import Label from "@/components/ui/label.astro";

// Local Card components
import Card from "@/components/ui/card/Card.astro";
import CardHeader from "@/components/ui/card/CardHeader.astro";
import CardTitle from "@/components/ui/card/CardTitle.astro";
import CardDescription from "@/components/ui/card/CardDescription.astro";
import CardContent from "@/components/ui/card/CardContent.astro";
import CardFooter from "@/components/ui/card/CardFooter.astro";

import { contactTopicGroups } from "@/lib/contact";
---

<Card>
  <form method="POST" action={submitContact} class="space-y-6">
    <CardHeader class="border-b pb-6">
      <CardTitle>Send me a Message</CardTitle>
      <CardDescription>
        I'll get back to you as soon as possible
      </CardDescription>
    </CardHeader>

    <CardContent>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="space-y-2">
          <Label>First Name *</Label>
          <Input name="firstName" placeholder="John" required />
        </div>
        <div class="space-y-2">
          <Label>Last Name *</Label>
          <Input name="lastName" placeholder="Doe" required />
        </div>
      </div>
      <div class="space-y-2 mt-6">
        <Label>Email *</Label>
        <Input name="email" type="email" placeholder="john@example.com" required />
      </div>
      <div class="space-y-2 mt-6">
        <Label>What are you contacting me about? *</Label>
        <select
          id="contact-service"
          name="service"
          required
          class="flex h-10 w-full rounded-md border border-input bg-input-background px-3 text-sm focus-visible:ring-2 focus-visible:ring-ring"
        >
          <option value="">Select one of the options</option>
          {contactTopicGroups.map((group) => (
            <optgroup label={group.label}>
              {group.options.map((option) => (
                <option value={option.label} data-hash={option.slug}>{option.label}</option>
              ))}
            </optgroup>
          ))}
        </select>
      </div>
      <div class="space-y-2 mt-6">
        <Label>Message *</Label>
        <Textarea name="message" placeholder="Tell me about your project..." required />
      </div>
    </CardContent>

    <CardFooter>
      <Button
        type="submit"
        variant="solid"
        bgColor="primary"
        hoverBgColor="primary"
        fullWidth={true}
        hoverScale="103"
      >
        Send Message
      </Button>
    </CardFooter>
  </form>
</Card>

<script>
  const syncContactCategoryFromHash = () => {
    const selectedHash = window.location.hash.replace(/^#/, "").trim().toLowerCase();
    if (!selectedHash) return;

    const select = document.getElementById("contact-service");
    if (!(select instanceof HTMLSelectElement)) return;

    const matchingOption = Array.from(select.options).find((option) => option.dataset.hash?.toLowerCase() === selectedHash);
    if (!matchingOption) return;

    select.value = matchingOption.value;
  };

  syncContactCategoryFromHash();
  window.addEventListener("hashchange", syncContactCategoryFromHash);
</script>
