---
import Card from "@/components/ui/card.astro";
import { Mail, MapPin } from "lucide-astro";
import { Icon } from "astro-icon/components";
import { socials } from "@/lib/socials";

const contactInfo = [
  {
    icon: Mail,
    label: "Email",
    value: "info@vintiquesound.com",
    href: "mailto:info@vintiquesound.com",
  },
  {
    icon: MapPin,
    label: "Address",
    value: "Edmonton AB",
    href: "https://maps.google.com",
  },
];


---

<div class="space-y-6">

  <Card>
    <div class="p-6 border-b">
      <h3 class="font-semibold">Contact Information</h3>
    </div>

    <div class="p-6 space-y-4">
      {contactInfo.map(({ icon: Icon, label, value, href }) => (
        <a
          href={href}
          target="_blank"
          class="flex gap-3 p-3 rounded-lg hover:bg-muted transition"
        >
          <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center">
            <Icon class="w-5 h-5 text-primary" />
          </div>

          <div>
            <div class="text-sm text-muted-foreground">{label}</div>
            <div class="font-medium">{value}</div>
          </div>
        </a>
      ))}
    </div>
  </Card>

  <Card>
    <div class="p-6 border-b">
      <h3 class="font-semibold">Follow Us</h3>
      <p class="text-sm text-muted-foreground">Stay connected</p>
    </div>

    <div class="p-6 space-y-3">
      {socials.map(({ iconName, name, url }) => (
        <a
          href={url}
          target="_blank"
          class="flex items-center gap-3 p-3 rounded-lg hover:bg-muted transition text-accent hover:text-secondary"
          aria-label={name}
        >
          <Icon name={iconName} size={20} />
          <span class="font-medium">{name}</span>
        </a>
      ))}
    </div>
  </Card>

</div>
