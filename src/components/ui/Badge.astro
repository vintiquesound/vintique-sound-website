---
// Props: text (string), bgColor (string, Tailwind classes), size ("sm" | "md" | "lg")
export interface BadgeProps {
  variant?: "solid" | "outline";
  bgColor?: string;
  text: string;
  size?: "sm" | "md" | "lg";
}

const {
  variant,
  bgColor,
  text,
  size,
} = Astro.props as BadgeProps;

const finalVariant = variant ?? "solid";
const finalBgColor = bgColor ?? (finalVariant === "solid"
  ? "bg-primary text-primary-foreground"
  : "bg-transparent border border-border text-foreground");
const finalSize = size ?? "md";
const sizeClasses = {
  sm: "px-2 py-0.5 text-xs",
  md: "px-4 py-1 text-sm",
  lg: "px-6 py-2 text-base",
}[finalSize] ?? "px-4 py-1 text-sm";
---
<span class={`inline-block rounded-md font-medium mb-4 ${sizeClasses} ${finalBgColor}`.trim()}>{text}</span>
