---
import type { HTMLAttributes } from "astro/types"
import { cva, type VariantProps } from "class-variance-authority"
import { cn } from "@/lib/utils"

const buttonVariants = cva(
  "inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md font-medium transition-all \
  disabled:pointer-events-none disabled:opacity-50 disabled:cursor-not-allowed \
  [&_svg]:pointer-events-none [&_svg:not([class*='size-'])]:size-4 shrink-0 [&_svg]:shrink-0 \
  outline-none focus-visible:ring-ring/50 focus-visible:ring-[3px] focus-visible:border-ring \
  aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 aria-invalid:border-destructive \
  bg-[var(--btn-bg)] hover:bg-[var(--btn-bg-hover)] text-[var(--btn-text)] hover:text-[var(--btn-text-hover)] \
  border-[var(--btn-border)] hover:border-[var(--btn-border-hover)]",
  {
    variants: {
      variant: {
        solid:
          "[--btn-bg:var(--primary)] [--btn-bg-hover:color-mix(in srgb,var(--primary) 90%,transparent)] [--btn-text:var(--primary-foreground)] [--btn-text-hover:var(--primary-foreground)] [--btn-border:transparent] [--btn-border-hover:transparent]",
        outline:
          "[--btn-bg:transparent] [--btn-bg-hover:color-mix(in srgb,var(--primary) 10%,transparent)] [--btn-text:var(--foreground)] [--btn-text-hover:var(--primary)] [--btn-border:var(--border)] [--btn-border-hover:var(--primary)]",
        destructive:
          "[--btn-bg:var(--destructive)] [--btn-bg-hover:color-mix(in srgb,var(--destructive) 90%,transparent)] [--btn-text:#fff] [--btn-text-hover:#fff] [--btn-border:transparent] [--btn-border-hover:transparent]",
        ghost:
          "[--btn-bg:transparent] [--btn-bg-hover:color-mix(in srgb,var(--accent) 15%,transparent)] [--btn-text:var(--foreground)] [--btn-text-hover:var(--accent)] [--btn-border:transparent] [--btn-border-hover:transparent]",
        text:
          "[--btn-bg:transparent] [--btn-bg-hover:transparent] [--btn-text:var(--foreground)] [--btn-text-hover:var(--primary)] [--btn-border:transparent] [--btn-border-hover:transparent]",
        link:
          "[--btn-bg:transparent] [--btn-bg-hover:transparent] [--btn-text:var(--primary)] [--btn-text-hover:var(--primary)] [--btn-border:transparent] [--btn-border-hover:transparent] underline-offset-4 hover:underline hover:scale-100",
      },
      size: {
        xs: "h-7 px-2.5 text-xs",
        sm: "h-8 px-3 text-sm",
        md: "h-9 px-4 text-sm",
        lg: "h-10 px-6 text-base",
        xl: "h-11 px-7 text-base",
        icon: "size-9",
        "icon-sm": "size-8",
        "icon-lg": "size-10",
      },
    },
    defaultVariants: {
      variant: "solid",
      size: "md",
    },
  }
)

type BorderMode = "none" | "hover" | "always"

const borderModeClass: Record<BorderMode, string> = {
  none: "border-0 hover:border-0",
  hover: "border border-transparent hover:border-[var(--btn-border-hover)]",
  always: "border border-[var(--btn-border)] hover:border-[var(--btn-border-hover)]",
}

const THEME_COLOR_KEYS = new Set([
  "background",
  "foreground",
  "text",
  "surface",
  "surface-2",
  "card",
  "card-foreground",
  "popover",
  "popover-foreground",
  "primary",
  "primary-foreground",
  "secondary",
  "secondary-foreground",
  "muted",
  "muted-foreground",
  "accent",
  "accent-foreground",
  "destructive",
  "destructive-foreground",
  "border",
  "ring",
  "input",
  "input-background",
  "switch-background",
  "sidebar",
  "sidebar-foreground",
  "sidebar-primary",
  "sidebar-primary-foreground",
  "sidebar-accent",
  "sidebar-accent-foreground",
  "sidebar-border",
  "sidebar-ring",
])

function resolveColorToken(value: string | undefined): string | undefined {
  if (!value) return undefined

  const trimmed = value.trim()
  if (!trimmed) return undefined

  if (
    trimmed.startsWith("var(") ||
    trimmed.startsWith("#") ||
    trimmed.startsWith("rgb(") ||
    trimmed.startsWith("rgba(") ||
    trimmed.startsWith("hsl(") ||
    trimmed.startsWith("hsla(") ||
    trimmed.startsWith("oklch(") ||
    trimmed.startsWith("oklab(") ||
    trimmed.startsWith("color-mix(")
  ) {
    return trimmed
  }

  const withoutPrefix = trimmed.replace(/^(text|bg|border)-/, "")

  const match = withoutPrefix.match(/^([a-zA-Z][\w-]*)(?:\/(\d{1,3}))?$/)
  if (!match) return trimmed

  const base = match[1] ?? ""
  const pctRaw = match[2]
  const pct = pctRaw ? Number(pctRaw) : undefined

  const baseColor = THEME_COLOR_KEYS.has(base) ? `var(--${base})` : base
  if (pct === undefined) return baseColor

  const clamped = Math.min(100, Math.max(0, pct))
  return `color-mix(in srgb, ${baseColor} ${clamped}%, transparent)`
}

type Props = Omit<HTMLAttributes<"button">, "class" | "style" | "type"> &
  Omit<HTMLAttributes<"a">, "class" | "style"> &
  VariantProps<typeof buttonVariants> & {
    asChild?: boolean
    href?: string
    type?: "button" | "submit" | "reset"

    fullWidth?: boolean

    usePointerCursor?: boolean
    pointerCursor?: boolean

    useHoverScale?: boolean
    /**
     * Custom hover scale. Examples:
     * - "103" -> hover:scale-103
     * - "scale-105" -> hover:scale-105
     * - "hover:scale-110" -> hover:scale-110
     * - "1.03" -> hover:scale-[1.03]
     */
    hoverScale?: boolean | string

    icon?: unknown
    iconPosition?: "left" | "right"
    iconClassName?: string

    bgColor?: string
    hoverBgColor?: string
    textColor?: string
    hoverTextColor?: string
    borderColor?: string
    hoverBorderColor?: string

    borderMode?: BorderMode
    borderNone?: boolean
    borderHover?: boolean
    borderAlways?: boolean

    class?: string
    className?: string
    style?: string
  }

const {
  class: classProp,
  className,
  style: styleProp,

  variant = "solid",
  size = "md",

  href,
  type = "button",

  fullWidth = false,

  usePointerCursor = true,
  pointerCursor,

  useHoverScale = true,
  hoverScale,

  icon,
  iconPosition = "left",
  iconClassName,

  bgColor,
  hoverBgColor,
  textColor,
  hoverTextColor,
  borderColor,
  hoverBorderColor,

  borderMode,
  borderNone,
  borderHover,
  borderAlways,

  // Supported for API parity with the React version.
  // Astro can't reliably "clone" slotted elements, so we only avoid
  // forwarding it to the DOM.
  asChild: _asChild,

  ...props
} = Astro.props as Props

const Element = href ? "a" : "button"

const resolvedPointerCursor = pointerCursor ?? usePointerCursor

const defaultHoverScaleEnabled = variant === "link" ? false : true

function normalizeHoverScaleClass(value: boolean | string | undefined): string | null {
  if (value === false) return null
  if (value === true || value === undefined) return "hover:scale-103"

  const trimmed = String(value).trim()
  if (!trimmed) return "hover:scale-103"

  // Support "hover:scale-105" / "scale-105" / "105" / "1.05".
  if (trimmed.startsWith("hover:scale-")) return trimmed
  if (trimmed.startsWith("scale-")) return `hover:${trimmed}`
  if (/^\d+(\.\d+)?$/.test(trimmed)) {
    // If > 10 treat as tailwind scale int (e.g. 103)
    if (Number(trimmed) > 10) return `hover:scale-${trimmed}`
    return `hover:scale-[${trimmed}]`
  }

  // Fall back to a safe default if input is weird.
  return "hover:scale-103"
}

const resolvedHoverScaleEnabled = useHoverScale ?? defaultHoverScaleEnabled
const hoverScaleClass = resolvedHoverScaleEnabled ? normalizeHoverScaleClass(hoverScale) : null

const defaultBorderMode: BorderMode = variant === "outline" ? "always" : "none"
const resolvedBorderMode: BorderMode = borderNone
  ? "none"
  : borderAlways
    ? "always"
    : borderHover
      ? "hover"
      : borderMode ?? defaultBorderMode

let variableStyles = ""

const bg = resolveColorToken(bgColor)
if (bg) variableStyles += `--btn-bg:${bg};`

const hoverBg = resolveColorToken(hoverBgColor)
if (hoverBg) variableStyles += `--btn-bg-hover:${hoverBg};`

const text = resolveColorToken(textColor)
if (text) variableStyles += `--btn-text:${text};`

const hoverText = resolveColorToken(hoverTextColor)
if (hoverText) variableStyles += `--btn-text-hover:${hoverText};`

const border = resolveColorToken(borderColor)
if (border) variableStyles += `--btn-border:${border};`

const hoverBorder = resolveColorToken(hoverBorderColor)
if (hoverBorder) variableStyles += `--btn-border-hover:${hoverBorder};`

const mergedStyle = [styleProp, variableStyles].filter(Boolean).join(" ").trim() || undefined

const mergedClass = cn(
  buttonVariants({ variant, size }),
  borderModeClass[resolvedBorderMode],
  fullWidth && "w-full",
  resolvedPointerCursor && "cursor-pointer",
  !resolvedPointerCursor && "cursor-default",
  hoverScaleClass,
  !hoverScaleClass && "hover:scale-100",
  classProp,
  className
)

const COLOR_UTILITY_RE =
  /(background|foreground|primary|primary-foreground|secondary|secondary-foreground|muted|muted-foreground|accent|accent-foreground|destructive|destructive-foreground|border|ring|white|black|transparent|current|inherit)/

function shouldStripColorUtility(token: string) {
  // Preserve the CSS-variable driven button utilities.
  // Example: `bg-[var(--btn-bg)]`, `hover:bg-[var(--btn-bg-hover)]`.
  if (token.includes("[var(--btn-")) return false

  const isArbitraryValue = token.includes("[")

  // Tailwind color alpha syntax: `bg-primary/80`. Avoid stripping URLs like `bg-[url('/x')]`.
  if (!isArbitraryValue && token.includes("/")) return true

  if (!token.includes("-")) return false

  // Allow sizes and other non-color utilities like `text-sm`.
  const maybeTextSize = token.match(/^text-(xs|sm|base|lg|xl|\d+xl)$/)
  if (maybeTextSize) return false

  // Don't accidentally strip opacity utilities.
  if (token.startsWith("bg-opacity-") || token.startsWith("text-opacity-")) return false

  // Keep common non-color background utilities like bg-cover.
  if (
    token.match(
      /^bg-(fixed|local|scroll|clip-(border|padding|content|text)|origin-(border|padding|content)|\w+-gradient-to-\w+|none|auto|cover|contain|top|bottom|left|right|center|no-repeat|repeat|repeat-x|repeat-y)$/
    )
  ) {
    return false
  }

  // Strip theme tokens like `bg-primary` and palette tokens like `bg-red-500`.
  if (COLOR_UTILITY_RE.test(token)) return true
  if (!isArbitraryValue && /-(\d{2,3})$/.test(token)) return true

  return false
}

const cleanedClass = mergedClass
  .split(/\s+/)
  .filter(Boolean)
  .filter((token) => {
    if (token.startsWith("bg-") || token.startsWith("hover:bg-")) return !shouldStripColorUtility(token)
    if (token.startsWith("text-") || token.startsWith("hover:text-")) return !shouldStripColorUtility(token)
    if (token.startsWith("border-") || token.startsWith("hover:border-")) return !shouldStripColorUtility(token)
    return true
  })
  .join(" ")

const Icon = icon as unknown as any
const iconIsComponent = typeof Icon === "function" || (typeof Icon === "object" && Icon !== null)
const hasIcon = Boolean(icon) && iconIsComponent

const hasDefaultSlot = Astro.slots.has("default")
const iconClasses = cn("size-[1em] text-current", iconClassName)
---

{Element === "a" ? (
  <a
    data-slot="button"
    data-variant={variant}
    data-size={size}
    href={href}
    class={cleanedClass}
    style={mergedStyle}
    {...props}
  >
    {hasIcon && iconPosition === "left" && <Icon class={iconClasses} className={iconClasses} />}

    {hasIcon ? (hasDefaultSlot ? <span><slot /></span> : null) : <slot />}

    {hasIcon && iconPosition === "right" && <Icon class={iconClasses} className={iconClasses} />}
  </a>
) : (
  <button
    data-slot="button"
    data-variant={variant}
    data-size={size}
    type={type}
    class={cleanedClass}
    style={mergedStyle}
    {...props}
  >
    {hasIcon && iconPosition === "left" && <Icon class={iconClasses} className={iconClasses} />}

    {hasIcon ? (hasDefaultSlot ? <span><slot /></span> : null) : <slot />}

    {hasIcon && iconPosition === "right" && <Icon class={iconClasses} className={iconClasses} />}
  </button>
)}
