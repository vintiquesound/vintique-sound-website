---
type Props = {
  /** Extra classes applied to the full-bleed outer <section> */
  class?: string;
};

const { class: outerClass = "" } = Astro.props as Props;

const inner = "mx-auto w-full max-w-200 px-4 sm:px-6 lg:px-8";
---

<section class={`relative w-full ${outerClass}`.trim()}>
  <div class={inner}>
    <slot />
  </div>
</section>
