---
type Props = {
  /** Extra classes applied to the full-bleed outer <section> */
  class?: string;
};

const { class: outerClass = "" } = Astro.props as Props;

const inner = "mx-auto w-full max-w-6xl px-4 sm:px-6 lg:px-8 xl:px-10 2xl:px-12";
---

<section class={`relative w-full overflow-hidden py-20 md:py-32 ${outerClass}`.trim()}>
  <div class="absolute inset-0 bg-linear-to-br from-primary/10 via-secondary/5 to-accent/10" />

  <div class={`${inner} relative z-10`}>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div>
        <slot name="left" />
      </div>
      <div>
        <slot name="right" />
      </div>
    </div>
  </div>
</section>
