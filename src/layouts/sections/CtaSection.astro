---
import SingleColumnContainer from "@/layouts/SingleColumnContainer.astro";
import CtaSectionCopy from "@/layouts/sections/CtaSectionCopy.astro";
import type { CtaButton } from "@/types/cta";

export type CtaSectionColors = [string] | [string, string] | [string, string, string];

type Props = {
  title: string;
  subtitle?: string;
  primary?: CtaButton;
  secondary?: CtaButton;
  align?: "center" | "left";
  colors?: CtaSectionColors;
  class?: string;
};

const {
  title,
  subtitle,
  primary,
  secondary,
  align = "center",
  colors = ["bg-primary"],
  class: outerClass = "",
} = Astro.props as Props;

const gradientClass = (() => {
  if (!colors?.length) return "bg-primary";
  if (colors.length === 1) return colors[0];
  if (colors.length === 2) return `bg-linear-to-br from-${colors[0]} to-${colors[1]}`;
  return `bg-linear-to-br from-${colors[0]} via-${colors[1]} to-${colors[2]}`;
})();
---

<section class={`w-full relative overflow-hidden ${outerClass}`.trim()}>
  <div class={`absolute inset-0 ${gradientClass}`} />
  <SingleColumnContainer innerClass="mx-auto w-full max-w-6xl px-4 sm:px-6 lg:px-8 xl:px-10 2xl:px-12" extraInnerClass="relative z-10">
    <CtaSectionCopy
      title={title}
      subtitle={subtitle}
      primary={primary}
      secondary={secondary}
      align={align}
    />
  </SingleColumnContainer>
</section>
