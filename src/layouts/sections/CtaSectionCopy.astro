---
import { buttonVariants } from "@/components/ui/button";
import { cn } from "@/lib/utils";
import type { CtaButton } from "@/types/cta";

type CtaSectionCopyProps = {
  title: string;
  subtitle?: string;
  primary: CtaButton;
  outline?: CtaButton;
  align?: "center" | "left";
};

const { title, subtitle, primary, outline, align = "center" } = Astro.props as CtaSectionCopyProps;

const PrimaryIcon = primary.icon;
const OutlineIcon = outline?.icon;

const alignment = align === "center" ? "items-center text-center" : "items-start text-left";
const actionsJustify = align === "center" ? "justify-center" : "justify-start";
---

<div class={`flex flex-col gap-6 ${alignment}`}>
  <div class="space-y-4">
    <h2 class="text-3xl md:text-4xl font-bold text-white">{title}</h2>
    {subtitle && (
      <p class="text-lg text-white/90 max-w-3xl">{subtitle}</p>
    )}
  </div>
  <div class={`flex flex-wrap gap-4 ${actionsJustify}`}>
      <a
        href={primary.href}
        data-slot="button"
        data-variant="default"
        data-size="lg"
        class={cn(
          buttonVariants({ variant: "default", size: "lg" }), primary.className)}
      >
        {PrimaryIcon && (primary.iconPosition ?? "left") === "left" && (
          <PrimaryIcon className="h-5 w-5" />
        )}
        <span>{primary.label}</span>
        {PrimaryIcon && (primary.iconPosition ?? "left") === "right" && (
          <PrimaryIcon className="h-5 w-5" />
        )}
      </a>
      {outline && (
        <a
          href={outline.href}
          data-slot="button"
          data-variant="outline"
          data-size="lg"
          class={cn(
            buttonVariants({ variant: "outline", size: "lg" }), outline.className)}
        >
          {OutlineIcon && (outline.iconPosition ?? "left") === "left" && (
            <OutlineIcon className="h-5 w-5" />
          )}
          <span>{outline.label}</span>
          {OutlineIcon && (outline.iconPosition ?? "left") === "right" && (
            <OutlineIcon className="h-5 w-5" />
          )}
        </a>
      )}
    </div>
</div>
