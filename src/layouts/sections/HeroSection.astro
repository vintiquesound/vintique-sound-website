---
import DualColumnContainer from "@/layouts/DualColumnContainer.astro";
import type { ImageMetadata } from "astro";
import type { CtaButton } from "@/types/cta";

import HeroSectionCopy from "@/layouts/sections/HeroSectionCopy.astro";
import HeroSectionImage from "@/layouts/sections/HeroSectionImage.astro";

type HeroSectionProps = {
	imagePosition?: "left" | "right";
	title: string;
	subtitle?: string;
  primary: CtaButton;
  secondary?: CtaButton;
	image: ImageMetadata;
	imageAlt: string;
};

const {
	imagePosition = "right",
	title,
	subtitle,
	primary,
	secondary,
	image,
	imageAlt,
} = Astro.props as HeroSectionProps;

const isImageLeft = imagePosition === "left";
---

<section class="w-full">
  <DualColumnContainer>
    <div slot="left">
			{isImageLeft ? (
				<HeroSectionImage image={image} imageAlt={imageAlt} />
			) : (
				<HeroSectionCopy
					title={title}
					subtitle={subtitle}
					primary={primary}
					secondary={secondary}
				/>
			)}
    </div>

    <div slot="right">
			{isImageLeft ? (
				<HeroSectionCopy
					title={title}
					subtitle={subtitle}
					primary={primary}
					secondary={secondary}
				/>
			) : (
				<HeroSectionImage image={image} imageAlt={imageAlt} />
			)}
    </div>
  </DualColumnContainer>
</section>
