---
import type { ImageMetadata } from "astro";
import type { CtaButton } from "@/types/cta";
import DualColumnContainer from "@/layouts/DualColumnContainer.astro";
import HeroSectionCopy from "@/layouts/sections/HeroSectionCopy.astro";
import HeroSectionImage from "@/layouts/sections/HeroSectionImage.astro";
import { buildBackgroundStyle, type BgColorToken } from "@/lib/backgrounds";

type HeroSectionProps = {
	imagePosition?: "left" | "right";
	title: string;
	subtitle?: string;
	bgColors?: BgColorToken[];
  solidButton: CtaButton;
  outlineButton?: CtaButton;
	image: ImageMetadata;
	imageAlt: string;
};

const {
	imagePosition = "right",
	title,
	subtitle,
	bgColors,
	solidButton,
	outlineButton,
	image,
	imageAlt,
} = Astro.props as HeroSectionProps;

const isImageLeft = imagePosition === "left";
const backgroundStyle = buildBackgroundStyle(bgColors);
---

<section class="w-full relative overflow-hidden">
	<div class="absolute inset-0" style={backgroundStyle} />
	<DualColumnContainer>
		<div slot="left">
			{isImageLeft ? (
				<HeroSectionImage image={image} imageAlt={imageAlt} />
			) : (
				<HeroSectionCopy
					title={title}
					subtitle={subtitle}
					solidButton={solidButton}
					outlineButton={outlineButton}
				/>
			)}
		</div>

		<div slot="right">
			{isImageLeft ? (
				<HeroSectionCopy
					title={title}
					subtitle={subtitle}
					solidButton={solidButton}
					outlineButton={outlineButton}
				/>
			) : (
				<HeroSectionImage image={image} imageAlt={imageAlt} />
			)}
		</div>
	</DualColumnContainer>
</section>
