---
// Local layout components
import DoubleColumnContainer from "@/layouts/DoubleColumnContainer.astro";
import HeroSectionContent from "@/layouts/sections/HeroSectionContent.astro";
import HeroSectionImage from "@/layouts/sections/HeroSectionImage.astro";

// Types and utilities
import type { ImageMetadata } from "astro";
import type { CtaButton } from "@/types/cta";

// Type definitions
type HeroSectionProps = {
	bgColors?: string;
	title: string;
	subtitle?: string;
  solidButton: CtaButton;
  outlineButton?: CtaButton;
	textLink?: {
		label: string;
		href: string;
	};
	image: ImageMetadata;
	imageAspect?: "responsive" | "square";
	imageSquareSizePx?: number;
	imagePosition?: "left" | "right";
	imageAlt: string;
	imageIsPriority?: boolean;
};

// Const definitions
const {
	bgColors,
	title,
	subtitle,
	solidButton,
	outlineButton,
	textLink,
	image,
	imageAspect,
	imageSquareSizePx,
	imagePosition = "right",
	imageAlt,
	imageIsPriority = false,
} = Astro.props as HeroSectionProps;

const isImageLeft = imagePosition === "left";
---

<section class="w-full relative overflow-hidden">
	<div class={`absolute inset-0 ${bgColors}`.trim()} />
	<DoubleColumnContainer>
		<div slot="left">
			{isImageLeft ? (
				<HeroSectionImage
					image={image}
					imageAlt={imageAlt}
					isPriority={imageIsPriority}
					{...(imageAspect ? { imageAspect } : {})}
					{...(imageSquareSizePx ? { imageSquareSizePx } : {})}
				/>
			) : (
				<HeroSectionContent
					title={title}
					subtitle={subtitle}
					solidButton={solidButton}
					outlineButton={outlineButton}
					textLink={textLink}
				/>
			)}
		</div>

		<div slot="right">
			{isImageLeft ? (
				<HeroSectionContent
					title={title}
					subtitle={subtitle}
					solidButton={solidButton}
					outlineButton={outlineButton}
					textLink={textLink}
				/>
			) : (
				<HeroSectionImage
					image={image}
					imageAlt={imageAlt}
					isPriority={imageIsPriority}
					{...(imageAspect ? { imageAspect } : {})}
					{...(imageSquareSizePx ? { imageSquareSizePx } : {})}
				/>
			)}
		</div>
	</DoubleColumnContainer>
</section>
