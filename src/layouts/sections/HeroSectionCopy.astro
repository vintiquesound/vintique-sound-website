---
import type { CtaButton } from "@/types/cta";
import Button from "@/components/ui/Button.astro";

type HeroSectionCopyProps = {
	title: string;
	subtitle?: string;
	solidButton: CtaButton;
	outlineButton?: CtaButton;
};

const { title, subtitle, solidButton, outlineButton } = Astro.props as HeroSectionCopyProps;

const solidButtonVariant = solidButton.variant ?? "solid";
const solidButtonSize = solidButton.size ?? "lg";
const outlineButtonVariant = outlineButton?.variant ?? "outline";
const outlineButtonSize = outlineButton?.size ?? "lg";
---

<div>
	<h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6">
		{title}
	</h1>
	{subtitle && (
		<p class="text-lg md:text-xl text-muted-foreground mb-8">{subtitle}</p>
	)}
	<div class="flex flex-wrap gap-4">
		<Button
			href={solidButton.href}
			variant={solidButtonVariant}
			size={solidButtonSize}
			fullWidth={solidButton.fullWidth}
			icon={solidButton.icon}
			iconPosition={solidButton.iconPosition}
			iconClassName={solidButton.iconClassName}
			bgColor={solidButton.bgColor}
			hoverBgColor={solidButton.hoverBgColor}
			textColor={solidButton.textColor}
			hoverTextColor={solidButton.hoverTextColor}
			borderColor={solidButton.borderColor}
			hoverBorderColor={solidButton.hoverBorderColor}
			borderMode={solidButton.borderMode}
			borderNone={solidButton.borderNone}
			borderHover={solidButton.borderHover}
			borderAlways={solidButton.borderAlways}
			hoverScale={solidButton.hoverScale}
			pointerCursor={solidButton.pointerCursor}
			className={solidButton.className}
		>
			{solidButton.label}
		</Button>
		{outlineButton && (
			<Button
				href={outlineButton.href}
				variant={outlineButtonVariant}
				size={outlineButtonSize}
				fullWidth={outlineButton.fullWidth}
				icon={outlineButton.icon}
				iconPosition={outlineButton.iconPosition}
				iconClassName={outlineButton.iconClassName}
				bgColor={outlineButton.bgColor}
				hoverBgColor={outlineButton.hoverBgColor}
				textColor={outlineButton.textColor}
				hoverTextColor={outlineButton.hoverTextColor}
				borderColor={outlineButton.borderColor}
				hoverBorderColor={outlineButton.hoverBorderColor}
				borderMode={outlineButton.borderMode}
				borderNone={outlineButton.borderNone}
				borderHover={outlineButton.borderHover}
				borderAlways={outlineButton.borderAlways}
				hoverScale={outlineButton.hoverScale}
				pointerCursor={outlineButton.pointerCursor}
				className={outlineButton.className}
			>
				{outlineButton.label}
			</Button>
		)}
	</div>
</div>
