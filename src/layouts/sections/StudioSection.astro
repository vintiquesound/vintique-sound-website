---
export type StudioSectionProps = {
  title: string;
  subtitle?: string;
  outerClass?: string;
  innerClass?: string;
};

const {
  title,
  subtitle,
  outerClass = "py-20 bg-muted",
  innerClass = "container mx-auto px-4",
} = Astro.props as StudioSectionProps;
---

<section class={outerClass}>
  <div class={innerClass}>
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">{title}</h2>
      {subtitle && (
        <p class="pb-0 mb-0 text-lg text-muted-foreground max-w-3xl mx-auto">
          {subtitle}
        </p>
      )}
    </div>
    <slot />
  </div>
</section>
