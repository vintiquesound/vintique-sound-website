---
// Astro layout and section components
import TripleColumnContainer from "@/layouts/TripleColumnContainer.astro";
import SingleColumnContainer from "@/layouts/SingleColumnContainer.astro";

// Local UI components
import Button from "@/components/ui/Button.astro";
import Card from "@/components/ui/card/Card.astro";
import CardContent from "@/components/ui/card/CardContent.astro";
import CardDescription from "@/components/ui/card/CardDescription.astro";
import CardFooter from "@/components/ui/card/CardFooter.astro";
import CardHeader from "@/components/ui/card/CardHeader.astro";
import CardTitle from "@/components/ui/card/CardTitle.astro";

type ColorStyle = "primary" | "secondary" | "accent";

type IconComponent = any;

type BulletItem = {
  text: string;
  icon?: IconComponent;
};

type CardButtonDef = {
  label: string;
  href: string;
  ariaLabel?: string;
  variant?: "solid" | "outline" | "destructive" | "ghost" | "text" | "link";
  bgColor?: string;
  hoverBgColor?: string;
  textColor?: string;
  hoverTextColor?: string;
  borderColor?: string;
  hoverBorderColor?: string;
};

type CardDef = {
  title: string;
  subtitle?: string;
  icon?: IconComponent;
  colorStyle?: ColorStyle;

  bullets?: BulletItem[];
  button?: CardButtonDef;
};

type ThreeCardsSectionProps = {
  class?: string;
  title: string;
  subtitle?: string;
  cards: [CardDef, CardDef, CardDef] | CardDef[];
};

const { class: outerClass = "", title, subtitle, cards } =
  Astro.props as ThreeCardsSectionProps;

const inner =
  "mx-auto w-full max-w-6xl px-4 sm:px-6 lg:px-8 xl:px-10 2xl:px-12";

function assertThreeCards(value: CardDef[]): asserts value is [CardDef, CardDef, CardDef] {
  if (!Array.isArray(value) || value.length < 3 || !value[0] || !value[1] || !value[2]) {
    throw new Error("ThreeCardsSection requires 3 cards.");
  }
}

const resolvedCards = [cards[0], cards[1], cards[2]];
assertThreeCards(resolvedCards);

function colorClasses(colorStyle?: ColorStyle) {
  switch (colorStyle) {
    case "secondary":
      return {
        hoverBorder: "hover:border-secondary",
        iconBg: "bg-secondary/10",
        iconText: "text-secondary",
      };
    case "accent":
      return {
        hoverBorder: "hover:border-accent",
        iconBg: "bg-accent/10",
        iconText: "text-accent",
      };
    case "primary":
    default:
      return {
        hoverBorder: "hover:border-primary",
        iconBg: "bg-primary/10",
        iconText: "text-primary",
      };
  }
}

type CardColorClasses = ReturnType<typeof colorClasses>;

type RenderCard = {
  card: CardDef;
  classes: CardColorClasses;
  bulletItems: BulletItem[];
};

const cardsWithClasses = resolvedCards.map((card): RenderCard => {
  const cardClasses = colorClasses(card.colorStyle);
  return {
    card,
    classes: cardClasses,
    bulletItems: card.bullets ?? [],
  };
}) as [RenderCard, RenderCard, RenderCard];
---

<section class={`w-full ${outerClass}`.trim()}>
  <SingleColumnContainer outerClass="pt-20" innerClass={inner}>
    <div class="mb-12 text-center">
      <h2 class="mb-4 text-3xl font-bold md:text-4xl">{title}</h2>
      {subtitle && (
        <p class="mx-auto max-w-2xl text-lg text-muted-foreground">
          {subtitle}
        </p>
      )}
    </div>
  </SingleColumnContainer>

  <TripleColumnContainer extraOuterClass="pt-0">
    <div slot="first">
      {(() => {
        const { card, classes: cardClasses, bulletItems } = cardsWithClasses[0];

        return (
          <Card class={`border-2 ${cardClasses.hoverBorder} flex h-full flex-col transition-all duration-300`}>
            <CardHeader class="flex-0">
              {card.icon && (
                <div
                  class={`mb-4 flex h-12 w-12 items-center justify-center rounded-lg ${cardClasses.iconBg}`}
                >
                  <card.icon class={`h-6 w-6 ${cardClasses.iconText}`} />
                </div>
              )}
              <CardTitle>{card.title}</CardTitle>
              <CardDescription class="md:min-h-16">
                {card.subtitle ?? ""}
              </CardDescription>
            </CardHeader>

            <CardContent class="flex-1">
              {bulletItems.length > 0 && (
                <ul class="space-y-2 mb-6">
                  {bulletItems.map(({ text, icon: BulletIcon }) => (
                    <li class="flex items-center gap-2 text-sm">
                      {BulletIcon && <BulletIcon class="h-4 w-4 text-secondary" />}
                      <span>{text}</span>
                    </li>
                  ))}
                </ul>
              )}
            </CardContent>

            {card.button && (
              <CardFooter>
                <Button
                  href={card.button.href}
                  aria-label={card.button.ariaLabel}
                  fullWidth
                  variant={card.button.variant ?? "solid"}
                  bgColor={card.button.bgColor}
                  hoverBgColor={card.button.hoverBgColor}
                  textColor={card.button.textColor}
                  hoverTextColor={card.button.hoverTextColor}
                  borderColor={card.button.borderColor}
                  hoverBorderColor={card.button.hoverBorderColor}
                >
                  {card.button.label}
                </Button>
              </CardFooter>
            )}
          </Card>
        );
      })()}
    </div>

    <div slot="second">
      {(() => {
        const { card, classes: cardClasses, bulletItems } = cardsWithClasses[1];

        return (
          <Card class={`border-2 ${cardClasses.hoverBorder} flex h-full flex-col transition-all duration-300`}>
            <CardHeader class="flex-0">
              {card.icon && (
                <div
                  class={`mb-4 flex h-12 w-12 items-center justify-center rounded-lg ${cardClasses.iconBg}`}
                >
                  <card.icon class={`h-6 w-6 ${cardClasses.iconText}`} />
                </div>
              )}
              <CardTitle>{card.title}</CardTitle>
              <CardDescription class="md:min-h-16">
                {card.subtitle ?? ""}
              </CardDescription>
            </CardHeader>

            <CardContent class="flex-1">
              {bulletItems.length > 0 && (
                <ul class="space-y-2 mb-6">
                  {bulletItems.map(({ text, icon: BulletIcon }) => (
                    <li class="flex items-center gap-2 text-sm">
                      {BulletIcon && <BulletIcon class="h-4 w-4 text-secondary" />}
                      <span>{text}</span>
                    </li>
                  ))}
                </ul>
              )}
            </CardContent>

            {card.button && (
              <CardFooter>
                <Button
                  href={card.button.href}
                  aria-label={card.button.ariaLabel}
                  fullWidth
                  variant={card.button.variant ?? "solid"}
                  bgColor={card.button.bgColor}
                  hoverBgColor={card.button.hoverBgColor}
                  textColor={card.button.textColor}
                  hoverTextColor={card.button.hoverTextColor}
                  borderColor={card.button.borderColor}
                  hoverBorderColor={card.button.hoverBorderColor}
                >
                  {card.button.label}
                </Button>
              </CardFooter>
            )}
          </Card>
        );
      })()}
    </div>

    <div slot="third">
      {(() => {
        const { card, classes: cardClasses, bulletItems } = cardsWithClasses[2];

        return (
          <Card class={`border-2 ${cardClasses.hoverBorder} flex h-full flex-col transition-all duration-300`}>
            <CardHeader class="flex-0">
              {card.icon && (
                <div
                  class={`mb-4 flex h-12 w-12 items-center justify-center rounded-lg ${cardClasses.iconBg}`}
                >
                  <card.icon class={`h-6 w-6 ${cardClasses.iconText}`} />
                </div>
              )}
              <CardTitle>{card.title}</CardTitle>
              <CardDescription class="md:min-h-16">
                {card.subtitle ?? ""}
              </CardDescription>
            </CardHeader>

            <CardContent class="flex-1">
              {bulletItems.length > 0 && (
                <ul class="space-y-2 mb-6">
                  {bulletItems.map(({ text, icon: BulletIcon }) => (
                    <li class="flex items-center gap-2 text-sm">
                      {BulletIcon && <BulletIcon class="h-4 w-4 text-secondary" />}
                      <span>{text}</span>
                    </li>
                  ))}
                </ul>
              )}
            </CardContent>

            {card.button && (
              <CardFooter>
                <Button
                  href={card.button.href}
                  aria-label={card.button.ariaLabel}
                  fullWidth
                  variant={card.button.variant ?? "solid"}
                  bgColor={card.button.bgColor}
                  hoverBgColor={card.button.hoverBgColor}
                  textColor={card.button.textColor}
                  hoverTextColor={card.button.hoverTextColor}
                  borderColor={card.button.borderColor}
                  hoverBorderColor={card.button.hoverBorderColor}
                >
                  {card.button.label}
                </Button>
              </CardFooter>
            )}
          </Card>
        );
      })()}
    </div>
  </TripleColumnContainer>
</section>
