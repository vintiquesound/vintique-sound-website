---
import type { ComponentProps } from "react";
import TripleColumnContainer from "@/layouts/TripleColumnContainer.astro";
import SingleColumnContainer from "@/layouts/SingleColumnContainer.astro";
import { Card, CardHeader, CardTitle, CardDescription, CardContent } from "@/components/ui/card";

type Accent = "primary" | "secondary" | "accent";

type CardDef = {
	title: string;
	subtitle?: string;
	icon?: (props: ComponentProps<"svg">) => any;
	accent?: Accent;
};

type Props = {
	/** Extra classes applied to the full section */
	class?: string;
	title: string;
	subtitle?: string;
	cards: [CardDef, CardDef, CardDef] | CardDef[];
};

const { class: outerClass = "", title, subtitle, cards } = Astro.props as Props;

const inner = "mx-auto w-full max-w-6xl px-4 sm:px-6 lg:px-8 xl:px-10 2xl:px-12";

const resolvedCards: [CardDef, CardDef, CardDef] = [cards[0], cards[1], cards[2]] as [
	CardDef,
	CardDef,
	CardDef,
];

const [card1, card2, card3] = resolvedCards;

const Icon1 = card1?.icon;
const Icon2 = card2?.icon;
const Icon3 = card3?.icon;

const classes1 = accentClasses(card1?.accent);
const classes2 = accentClasses(card2?.accent);
const classes3 = accentClasses(card3?.accent);

function accentClasses(accent: Accent | undefined) {
	switch (accent) {
		case "secondary":
			return {
				hoverBorder: "hover:border-secondary",
				iconBg: "bg-secondary/10",
				iconText: "text-secondary",
			};
		case "accent":
			return {
				hoverBorder: "hover:border-accent",
				iconBg: "bg-accent/10",
				iconText: "text-accent",
			};
		case "primary":
		default:
			return {
				hoverBorder: "hover:border-primary",
				iconBg: "bg-primary/10",
				iconText: "text-primary",
			};
	}
}
---

<section class={`w-full ${outerClass}`.trim()}>
	<SingleColumnContainer outerClass="pt-20" innerClass={inner}>
		<div class="text-center mb-12">
			<h2 class="text-3xl md:text-4xl font-bold mb-4">{title}</h2>
			{subtitle && (
				<p class="text-lg text-muted-foreground max-w-2xl mx-auto">{subtitle}</p>
			)}
		</div>
	</SingleColumnContainer>

	<TripleColumnContainer extraOuterClass="pt-0">
		<div slot="first">
			<Card className={`border-2 ${classes1.hoverBorder} transition-all duration-300`}>
				<CardHeader>
					{Icon1 && (
						<div
							class={`w-12 h-12 rounded-lg ${classes1.iconBg} flex items-center justify-center mb-4`}
						>
							<Icon1 className={`h-6 w-6 ${classes1.iconText}`} />
						</div>
					)}
					<CardTitle>{card1?.title}</CardTitle>
					{card1?.subtitle && <CardDescription>{card1.subtitle}</CardDescription>}
				</CardHeader>
				<CardContent>
					{Astro.slots.has("card1Content") && <slot name="card1Content" />}
					{Astro.slots.has("card1Footer") && <slot name="card1Footer" />}
				</CardContent>
			</Card>
		</div>

		<div slot="second">
			<Card className={`border-2 ${classes2.hoverBorder} transition-all duration-300`}>
				<CardHeader>
					{Icon2 && (
						<div
							class={`w-12 h-12 rounded-lg ${classes2.iconBg} flex items-center justify-center mb-4`}
						>
							<Icon2 className={`h-6 w-6 ${classes2.iconText}`} />
						</div>
					)}
					<CardTitle>{card2?.title}</CardTitle>
					{card2?.subtitle && <CardDescription>{card2.subtitle}</CardDescription>}
				</CardHeader>
				<CardContent>
					{Astro.slots.has("card2Content") && <slot name="card2Content" />}
					{Astro.slots.has("card2Footer") && <slot name="card2Footer" />}
				</CardContent>
			</Card>
		</div>

		<div slot="third">
			<Card className={`border-2 ${classes3.hoverBorder} transition-all duration-300`}>
				<CardHeader>
					{Icon3 && (
						<div
							class={`w-12 h-12 rounded-lg ${classes3.iconBg} flex items-center justify-center mb-4`}
						>
							<Icon3 className={`h-6 w-6 ${classes3.iconText}`} />
						</div>
					)}
					<CardTitle>{card3?.title}</CardTitle>
					{card3?.subtitle && <CardDescription>{card3.subtitle}</CardDescription>}
				</CardHeader>
				<CardContent>
					{Astro.slots.has("card3Content") && <slot name="card3Content" />}
					{Astro.slots.has("card3Footer") && <slot name="card3Footer" />}
				</CardContent>
			</Card>
		</div>
	</TripleColumnContainer>
</section>
