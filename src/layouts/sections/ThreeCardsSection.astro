---
import TripleColumnContainer from "@/layouts/TripleColumnContainer.astro";
import SingleColumnContainer from "@/layouts/SingleColumnContainer.astro";

import Card from "@/components/ui/card/Card.astro";
import CardHeader from "@/components/ui/card/CardHeader.astro";
import CardTitle from "@/components/ui/card/CardTitle.astro";
import CardDescription from "@/components/ui/card/CardDescription.astro";
import CardContent from "@/components/ui/card/CardContent.astro";

type ColorStyle = "primary" | "secondary" | "accent";

type CardDef = {
  title: string;
  subtitle?: string;
  icon?: any;
  colorStyle?: ColorStyle;
};

type ThreeCardsSectionProps = {
  class?: string;
  title: string;
  subtitle?: string;
  cards: [CardDef, CardDef, CardDef] | CardDef[];
};

const { class: outerClass = "", title, subtitle, cards } =
  Astro.props as ThreeCardsSectionProps;

const inner =
  "mx-auto w-full max-w-6xl px-4 sm:px-6 lg:px-8 xl:px-10 2xl:px-12";

const resolvedCards = [cards[0], cards[1], cards[2]] as [
  CardDef,
  CardDef,
  CardDef
];

const [card1, card2, card3] = resolvedCards;

const Icon1 = card1?.icon;
const Icon2 = card2?.icon;
const Icon3 = card3?.icon;

function colorClasses(colorStyle?: ColorStyle) {
  switch (colorStyle) {
    case "secondary":
      return {
        hoverBorder: "hover:border-secondary",
        iconBg: "bg-secondary/10",
        iconText: "text-secondary",
      };
    case "accent":
      return {
        hoverBorder: "hover:border-accent",
        iconBg: "bg-accent/10",
        iconText: "text-accent",
      };
    case "primary":
    default:
      return {
        hoverBorder: "hover:border-primary",
        iconBg: "bg-primary/10",
        iconText: "text-primary",
      };
  }
}

const classes1 = colorClasses(card1?.colorStyle);
const classes2 = colorClasses(card2?.colorStyle);
const classes3 = colorClasses(card3?.colorStyle);
---

<section class={`w-full ${outerClass}`.trim()}>
  <SingleColumnContainer outerClass="pt-20" innerClass={inner}>
    <div class="mb-12 text-center">
      <h2 class="mb-4 text-3xl font-bold md:text-4xl">{title}</h2>
      {subtitle && (
        <p class="mx-auto max-w-2xl text-lg text-muted-foreground">
          {subtitle}
        </p>
      )}
    </div>
  </SingleColumnContainer>

  <TripleColumnContainer extraOuterClass="pt-0">
    <div slot="first">
      <Card class={`border-2 ${classes1.hoverBorder} transition-all duration-300`}>
        <CardHeader>
          {Icon1 && (
            <div
              class={`mb-4 flex h-12 w-12 items-center justify-center rounded-lg ${classes1.iconBg}`}
            >
              <Icon1 class={`h-6 w-6 ${classes1.iconText}`} />
            </div>
          )}
          <CardTitle>{card1.title}</CardTitle>
          {card1.subtitle && (
            <CardDescription>{card1.subtitle}</CardDescription>
          )}
        </CardHeader>

        <CardContent>
          {Astro.slots.has("card1Content") && <slot name="card1Content" />}
          {Astro.slots.has("card1Footer") && <slot name="card1Footer" />}
        </CardContent>
      </Card>
    </div>

    <div slot="second">
      <Card class={`border-2 ${classes2.hoverBorder} transition-all duration-300`}>
        <CardHeader>
          {Icon2 && (
            <div
              class={`mb-4 flex h-12 w-12 items-center justify-center rounded-lg ${classes2.iconBg}`}
            >
              <Icon2 class={`h-6 w-6 ${classes2.iconText}`} />
            </div>
          )}
          <CardTitle>{card2.title}</CardTitle>
          {card2.subtitle && (
            <CardDescription>{card2.subtitle}</CardDescription>
          )}
        </CardHeader>

        <CardContent>
          {Astro.slots.has("card2Content") && <slot name="card2Content" />}
          {Astro.slots.has("card2Footer") && <slot name="card2Footer" />}
        </CardContent>
      </Card>
    </div>

    <div slot="third">
      <Card class={`border-2 ${classes3.hoverBorder} transition-all duration-300`}>
        <CardHeader>
          {Icon3 && (
            <div
              class={`mb-4 flex h-12 w-12 items-center justify-center rounded-lg ${classes3.iconBg}`}
            >
              <Icon3 class={`h-6 w-6 ${classes3.iconText}`} />
            </div>
          )}
          <CardTitle>{card3.title}</CardTitle>
          {card3.subtitle && (
            <CardDescription>{card3.subtitle}</CardDescription>
          )}
        </CardHeader>

        <CardContent>
          {Astro.slots.has("card3Content") && <slot name="card3Content" />}
          {Astro.slots.has("card3Footer") && <slot name="card3Footer" />}
        </CardContent>
      </Card>
    </div>
  </TripleColumnContainer>
</section>
