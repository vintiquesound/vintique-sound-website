---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import { BLOG_TITLE, BLOG_DESCRIPTION } from "@/consts";
import Layout from "../../layouts/WebPageLayout.astro";
import FormattedDate from "../../components/FormattedDate.astro";

const posts = (await getCollection("blog"))
	.filter((p) => (p.data.draft ?? false) === false)
	.filter((p) => (p.data.published ?? true) === true)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title={BLOG_TITLE} description={BLOG_DESCRIPTION}>
	<section class="w-full">
		<div class="my-8 mx-auto w-full max-w-200 px-4 sm:px-6 lg:px-8">
			<ul class="grid list-none grid-cols-1 gap-2 p-0 md:grid-cols-2 md:gap-8">
			{
				posts.map((post, idx) => (
					<li
						class:list={{
							"text-center": idx === 0,
							"md:col-span-2 md:mb-4": idx === 0,
						}}
					>
						<a
							href={`/blog/${post.slug}/`}
							class="group block no-underline transition"
						>
							{post.data.heroImage && (
								<Image
									width={720}
									height={360}
									src={post.data.heroImage}
									alt=""
									class="mb-2 block w-full h-auto rounded-xl transition-shadow duration-200 ease-out group-hover:shadow-(--shadow-1)"
								/>
							)}
							<h4
								class:list={{
									"m-0 font-semibold leading-none text-foreground transition-colors duration-200 ease-out group-hover:text-accent": true,
									"text-2xl md:text-4xl": idx === 0,
									"text-xl": idx !== 0,
								}}
							>
								{post.data.title}
							</h4>
							<p class="m-0 text-muted-foreground transition-colors duration-200 ease-out group-hover:text-accent">
								<FormattedDate date={post.data.pubDate} />
							</p>
						</a>
					</li>
				))
			}
			</ul>
		</div>
	</section>
</Layout>
