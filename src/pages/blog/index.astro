---
// Astro layout and section components
import WebPageLayout from "@/layouts/WebPageLayout.astro";
import SingleColumnContainer from "@/layouts/SingleColumnContainer.astro";

// Third party libraries
import { Image } from "astro:assets";
import { getCollection } from "astro:content";

// Local content and assets
import { BLOG_TITLE, BLOG_DESCRIPTION } from "@/consts";
import { blogEntryIdToSlug } from "@/lib/utils";

// Types and utilities
import FormattedDate from "@/components/FormattedDate.astro";

export const prerender = true;

// Const definitions
const posts = (await getCollection("blog"))
	.filter((p) => (p.data.draft ?? false) === false)
	.filter((p) => (p.data.published ?? true) === true)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<WebPageLayout title={BLOG_TITLE} description={BLOG_DESCRIPTION}>
	<section class="w-full">
    <SingleColumnContainer outerClass="py-10">
      <h1 class="m-0 text-center text-accent">Vintique Sound</h1>
      <p class="mt-2 mb-0 text-center text-muted-foreground">
        Tutorials, tips & tricks, reviews, and more.
      </p>
      <div class="flex justify-center">
        <hr class="w-16 h-1 rounded-full border-0 bg-accent my-4" />
      </div>
    </SingleColumnContainer>
		<div class="mb-8 mx-auto w-full max-w-200 px-4 sm:px-6 lg:px-8">
			<ul class="grid list-none grid-cols-1 gap-2 p-0 md:grid-cols-2 md:gap-8">
			{
				posts.map((post, idx) => (
					<li
						class:list={{
							"text-center": idx === 0,
							"md:col-span-2 md:mb-4": idx === 0,
						}}
					>
						<a
							href={`/blog/${blogEntryIdToSlug(post.id)}/`}
							class="group block no-underline transition"
						>
							{post.data.heroImage && (
								<Image
									width={720}
									height={360}
									src={post.data.heroImage}
									alt=""
									class="mb-2 block w-full h-auto rounded-xl transition-shadow duration-200 ease-out group-hover:shadow-(--shadow-1)"
								/>
							)}
							<h4
								class:list={{
									"m-0 font-semibold leading-none text-foreground transition-colors duration-200 ease-out group-hover:text-accent uppercase": true,
									"text-2xl md:text-4xl": idx === 0,
									"text-xl": idx !== 0,
								}}
							>
								{post.data.title}
							</h4>
						</a>
            <div class="m-0">
              <FormattedDate date={post.data.pubDate} />
            </div>
					</li>
				))
			}
			</ul>
		</div>
	</section>
</WebPageLayout>
