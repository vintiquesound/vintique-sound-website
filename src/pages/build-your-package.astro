---
// Astro layout and section components
import WebPageLayout from "@/layouts/WebPageLayout.astro";
import IntroSection from "@/layouts/sections/IntroSection.astro";

// Local UI components
import { BUILD_PACKAGE_TITLE, BUILD_PACKAGE_DESCRIPTION } from "@/consts";
import PackageBuilderIsland from "@/components/build-your-package/PackageBuilderIsland";
---

<WebPageLayout title={BUILD_PACKAGE_TITLE} description={BUILD_PACKAGE_DESCRIPTION}>

  {/* INTRO SECTION */}
  <IntroSection
    bgColors="bg-linear-to-br from-primary/20 to-secondary/20"
    badgeText="Build Your Package"
    badgeColor="bg-primary text-primary-foreground"
    title="Build Your Custom Package"
    subtitle="Customize the right audio service package or build a tailored 1-on-1 training request."
    align="center"
  />

  <section class="py-20">
    <div class="container mx-auto px-4 max-w-6xl">
      <!-- React Island -->
      <PackageBuilderIsland client:load />
    </div>
  </section>

</WebPageLayout>
