---
// Astro layout and section components
import WebPageLayout from "@/layouts/WebPageLayout.astro";
import IntroSection from "@/layouts/sections/IntroSection.astro";

// Local UI components
import ContactFormCard from "@/components/forms/contact/ContactFormCard.astro";
import ContactInfoCard from "@/components/cards/contact/ContactInfoCard.astro";
import ContactSocialsCard from "@/components/cards/contact/ContactSocialsCard.astro";
// import OpenStreetMapEmbed from "@/components/maps/OpenStreetMapEmbed.astro";
import OpenStreetMapLeaflet from "@/components/maps/OpenStreetMapLeaflet.astro";

// Local content and assets
import { CONTACT_TITLE, CONTACT_DESCRIPTION } from "@/consts";
---

<WebPageLayout title={CONTACT_TITLE} description={CONTACT_DESCRIPTION}>
  <div class="flex flex-col">

    {/* Intro Section */}
    <IntroSection
      bgColors="bg-linear-to-br from-primary/20 to-accent/20"
      badgeText="Contact"
      badgeColor="bg-primary text-primary-foreground"
      title="Let's Create Something<br/>Awesome"
      subtitle="Have a project in mind? Want to learn more about my services?<br/>I'd love to hear from you."
      align="center"
    />

    {/* Contact Section */}
    <section class="py-20 bg-muted">
      <div class="container mx-auto px-4 grid grid-cols-1 lg:grid-cols-3 gap-12">
        <div class="lg:col-span-2">
          <div id="request-training" class="scroll-mt-24"></div>
          <div id="one-on-one-training" class="scroll-mt-24"></div>
          <ContactFormCard />
        </div>
        <div class="flex flex-col w-full gap-y-12 lg:col-span-1">
          <ContactInfoCard />
          <ContactSocialsCard />
        </div>
      </div>
    </section>

    {/* Map Section */}
    <section class="py-20 bg-background">
      <div class="container mx-auto px-4 max-w-4xl text-center">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">My Location</h2>
        <p class="text-lg text-muted-foreground mb-8">
          Located in the heart of Edmonton AB
        </p>
        <!-- <OpenStreetMapEmbed lat={53.54601} lon={-113.49143} offset={0.02} /> -->
        <OpenStreetMapLeaflet lat={53.543623} lon={-113.517814} zoom={13} />
      </div>
    </section>

  </div>
</WebPageLayout>
