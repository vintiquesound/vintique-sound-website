---
import WebPageLayout from "@/layouts/WebPageLayout.astro";
import IntroSection from "@/layouts/sections/IntroSection.astro";
import ContactFormCard from "@/components/contact/ContactFormCard.astro";
import ContactInfoCard from "@/components/contact/ContactInfoCard.astro";
import ContactSocialsCard from "@/components/contact/ContactSocialsCard.astro";
import OpenStreetMapEmbed from "@/components/contact/OpenStreetMapEmbed.astro";
---

<WebPageLayout title="Contact" description="Reach out to Vintique Sound for audio services, lessons, or questions.">
  <div class="flex flex-col">

    {/* Intro Section */}
    <IntroSection
      bgColors="bg-linear-to-br from-primary/20 to-accent/20"
      badgeText="Contact"
      badgeColor="bg-primary text-primary-foreground"
      title="Let's Create Something<br/>Awesome"
      subtitle="Have a project in mind? Want to learn more about my services?<br/>I'd love to hear from you."
      align="center"
    />

    {/* Contact Section */}
    <section class="py-20 bg-muted">
      <div class="container mx-auto px-4 grid grid-cols-1 lg:grid-cols-3 gap-12">
        <div class="lg:col-span-2">
          <ContactFormCard />
        </div>
        <div class="flex flex-col w-full gap-y-12 lg:col-span-1">
          <ContactInfoCard />
          <ContactSocialsCard />
        </div>
      </div>
    </section>

    {/* Map Section */}
    <section class="py-20 bg-background">
      <div class="container mx-auto px-4 max-w-4xl text-center">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">My Location</h2>
        <p class="text-lg text-muted-foreground mb-8">
          Located in the heart of Edmonton AB
        </p>
        <OpenStreetMapEmbed lat={53.54601} lon={-113.49143} offset={0.02} />
      </div>
    </section>

  </div>
</WebPageLayout>
