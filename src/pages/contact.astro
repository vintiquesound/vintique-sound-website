---
import ContactForm from "@/components/contact/ContactForm.astro";
import ContactInfoCard from "@/components/contact/ContactInfoCard.astro";
import { MapPin } from "lucide-astro";
---

<div class="flex flex-col">

  <section class="relative py-20 md:py-32">
    <div class="absolute inset-0 bg-gradient-to-br from-primary/10 to-accent/10"></div>

    <div class="container mx-auto px-4 relative z-10 text-center max-w-3xl">
      <span class="inline-block mb-4 rounded-full bg-primary px-4 py-1 text-sm font-medium text-primary-foreground">
        Contact
      </span>

      <h1 class="text-4xl md:text-5xl font-bold mb-6">
        Let's Create Something Amazing
      </h1>

      <p class="text-lg md:text-xl text-muted-foreground">
        Have a project in mind? We'd love to hear from you.
      </p>
    </div>
  </section>

  <section class="py-20">
    <div class="container mx-auto px-4 grid grid-cols-1 lg:grid-cols-3 gap-12">
      <div class="lg:col-span-2">
        <ContactForm />
      </div>

      <ContactInfoCard />
    </div>
  </section>

  <section class="py-20 bg-muted/50">
    <div class="container mx-auto px-4 max-w-4xl text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Visit Our Studio</h2>
      <p class="text-lg text-muted-foreground mb-8">
        Located in the heart of Los Angeles
      </p>

      <div class="h-[400px] rounded-2xl border bg-muted flex items-center justify-center">
        <MapPin class="w-12 h-12 text-muted-foreground" />
      </div>
    </div>
  </section>

</div>
