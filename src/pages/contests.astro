---
// Astro layout and section components
import WebPageLayout from "@/layouts/WebPageLayout.astro";
import SingleColumnContainer from "@/layouts/SingleColumnContainer.astro";
import CtaSection from "@/layouts/sections/CtaSection.astro";

// Local UI components
import Card from "@/components/ui/card/Card.astro";
import CardHeader from "@/components/ui/card/CardHeader.astro";
import CardTitle from "@/components/ui/card/CardTitle.astro";
import CardContent from "@/components/ui/card/CardContent.astro";

// Local content and assets
import { CONTESTS_TITLE, CONTESTS_DESCRIPTION } from "@/consts";
---

<WebPageLayout title={CONTESTS_TITLE} description={CONTESTS_DESCRIPTION}>
  <SingleColumnContainer
    outerClass="py-16 sm:py-20"
    extraOuterClass="bg-linear-to-br from-accent/20 to-secondary/20"
    innerClass="mx-auto max-w-2xl"
  >
      <Card class="px-4 py-12 border-2 border-border/70 bg-background/85 shadow-(--shadow-1)">
        <CardHeader class="items-center text-center">
          <CardTitle class="text-3xl leading-tight sm:text-4xl">
            No Active Contests Right Now
          </CardTitle>
        </CardHeader>
        <CardContent class="pt-0 text-center">
          <p class="m-0 text-sm text-muted-foreground sm:text-base">
            There are currently no live giveaways or contests.<br/>
            New opportunities are planned, so please check back soon for future announcements.
          </p>
        </CardContent>
      </Card>
  </SingleColumnContainer>

  <CtaSection
    bgColors="bg-linear-to-br from-accent via-accent/80 to-secondary"
    title="While You Wait"
    subtitle="No contests are running right now, but you can still explore services and resources to move your next project forward."
    solid={{
      label: "Mixing & Mastering Services",
      href: "/mixing-and-mastering"
    }}
    outline={{
      label: "Read the Blog",
      href: "/blog",
      hoverTextColor: "accent",
      hoverBorderColor: "accent",
    }}
  />
</WebPageLayout>

