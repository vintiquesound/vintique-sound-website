---
import { ArrowRight } from "lucide-astro";
import WebPageLayout from "@/layouts/WebPageLayout.astro";
import IntroSection from "@/layouts/sections/IntroSection.astro";
import Accordion from "@/components/ui/Accordion.astro"
import CtaSection from "@/layouts/sections/CtaSection.astro";

const faqs = {
  services: [
    {
      question: "What's the difference between mixing and mastering?",
      answer: "Mixing is the process of balancing and blending individual tracks in a song - adjusting levels, EQ, compression, effects, and spatial placement. Mastering is the final step where the mixed track is polished, optimized for different playback systems, and prepared for distribution. Think of mixing as assembling the puzzle pieces, and mastering as putting the frame around the completed picture."
    },
    {
      question: "How long does a typical mix or master take?",
      answer: "Mixing typically takes 2-5 days depending on track complexity and revision rounds. Mastering is usually completed within 1-3 days. We offer rush services for urgent projects at an additional fee. Our standard packages include turnaround times and revision policies to ensure you get exactly what you need."
    },
    {
      question: "What file formats do you accept and deliver?",
      answer: "We accept WAV, FLAC, and AIFF (basically anything lossless). For stems, we prefer 24-bit/48kHz or higher. We deliver masters in any format of your choice including WAV, FLAC, MP3, and streaming-optimized files. We can also provide masters for specific platforms like Spotify, Apple Music, or other streaming platforms."
    },
    {
      question: "How many revisions are included?",
      answer: "Our Mixing package includes up to 3 revisions, Mastering includes 2 revisions, and our Mix+Master bundle includes unlimited revisions. We want you to be completely satisfied with the final result. Additional revisions beyond the package limit can be purchased if needed."
    },
    {
      question: "Do you work remotely or do I need to come to the studio?",
      answer: "All of our services are provided remotely. Though we have a professional studio, it was not designed for in person sessions. Our clients send files remotely through our secure file transfer system or through services like WeTransfer, and we communicate via email or video calls."
    },
    {
      question: "What's your refund policy for audio related services?",
      answer: "All Audio Engineering Services purchases require a non-refundable deposit worth 25% of the total sale price in order to book the service and choose a project start date. We offer a 30-day money-back guarantee on all audio engineering services for the remaining 75% of the sale price. If you're not satisfied with your purchase, contact us within 30 days for a 75% refund. We do require that you provide feedback on why the service didn't meet your expectations."
    }
  ],
  education: [
    {
      question: "Are the courses suitable for beginners?",
      answer: "Yes! We have courses designed for all skill levels. Each course is clearly labeled as Beginner, Intermediate, or Advanced. Our beginner courses start from the absolute basics and gradually build your skills. We also offer free introductory tutorials to help you get started."
    },
    {
      question: "Do I get lifetime access to the courses?",
      answer: "Absolutely! Once you purchase a course, you have unlimited lifetime access to all course materials, including any future updates. You can learn at your own pace and revisit lessons whenever you need a refresher."
    },
    {
      question: "What software do I need for the courses?",
      answer: "Many courses are DAW-agnostic, meaning the concepts apply to any digital audio workstation. However, we do have specific tutorials for Cubase Pro and those courses make it clear which version is being used. Each course description lists any specific software requirements."
    },
    {
      question: "Can I get a certificate after completing a course?",
      answer: "Unfortunately no. We do not provide any form of digital or physical certificate. Our learning materials are created for general educational purposes and are not structured to meet formal accreditation requirements."
    },
    {
      question: "What's your refund policy for educational content?",
      answer: "We offer a 14-day money-back guarantee on all educational content. If you're not satisfied with your purchase, contact us within 14 days for a full refund. We do require that you provide feedback on why the product didn't meet your expectations."
    }
  ],
  products: [
    {
      question: "Are your sample packs and loops royalty-free?",
      answer: "Yes! All our sample packs and loops are 100% royalty-free. You can use them in your commercial releases without any additional fees or credits required. You own the rights to use the samples in your productions. You may not, however, redistribute the sample and loop packs (giving away or selling the sample and loop packs is a breach of copyright laws)."
    },
    {
      question: "What formats are the plugins available in?",
      answer: "Our plugins are available in VST, VST3, AU (Audio Unit), and AAX formats. They work with Mac, Windows, and Linux operating systems. System requirements are listed on each product page."
    },
    {
      question: "Can I try plugins before purchasing?",
      answer: "Yes! We offer fully functional 14-day trial versions of all our plugins. You can download them from the product page and use them in your projects. If you decide to purchase, your trial projects will continue to work seamlessly."
    },
    {
      question: "What's your refund policy for digital products?",
      answer: "We offer a 14-day money-back guarantee on all digital products. If you're not satisfied with your purchase, contact us within 14 days for a full refund. We do require that you provide feedback on why the product didn't meet your expectations."
    }
  ],
  technical: [
    {
      question: "What's your studio's analog signal chain?",
      answer: "Unfortunately we do not have a dedicated analog signal chain. We've experimented in the past using a hybrid setup, but opted for a more flexible fully digital in-the-box approach. We've decided to use high quality analog modeling like the new Universal Audio UADx plugins."
    },
    {
      question: "Do you offer stem mastering?",
      answer: "Yes! Stem mastering is available as its own service. You can provide individual stems (drums, bass, vocals, instruments, etc.) which gives us more control over the final balance while maintaining the cohesion of a full mix master. This is particularly useful for EDM and hip-hop productions."
    },
    {
      question: "Can you master for vinyl?",
      answer: "Unfortunately we do not have the expertise to guarantee a high quality vinyl master! As much as we love vinyl records, we cannot guarantee that attempting a vinyl master would yield appropriate frequency adjustments, stereo width management, and level optimizations."
    },
    {
      question: "What monitoring system do you use?",
      answer: "Our main monitoring is done on Neumann KH 310 three-way monitors in an acoustically treated room. We also reference on Avantone MixCubes and Focal Spirit Headphones to ensure your mixes and/or masters translate well across different playback systems."
    },
    {
      question: "Do you collaborate with other artists?",
      answer: "Yes! I'm able to collaborate using Steinberg Cubase's VST Connect, or by sharing complete project files (either Cubase, Ableton, or Bitwig projects)."
    }
  ]
};
---

<WebPageLayout title="Contact" description="Reach out to Vintique Sound for audio services, lessons, or questions.">
  <div class="flex flex-col">

    {/* Generic Section */}
    <IntroSection
      badge="FAQ"
      badgeColor="bg-primary text-primary-foreground"
      title="Frequently Asked Questions"
      subtitle="Find answers to common questions about our services, courses, and products."
			bgColors="bg-linear-to-br from-secondary/15 to-accent/15"
      align="center"
      outerClass="py-20 md:py-32"
    />

    {/* FAQ Section */}
    <section class="py-20 bg-muted">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto space-y-12">

          <!-- Services -->
          <Accordion
            title="Services"
            accentColor="primary"
            items={faqs.services}
            singleOpen={true}
          />

          <!-- Education -->
           <Accordion
            title="Education"
            accentColor="secondary"
            items={faqs.education}
            singleOpen={true}
          />

          <!-- Digital Products -->
          <Accordion
            title="Digital Products"
            accentColor="accent"
            items={faqs.products}
            singleOpen={true}
          />

          <!-- Technical -->
          <Accordion
            title="Technical Details"
            accentColor="primary"
            items={faqs.products}
            singleOpen={true}
          />

        </div>
      </div>
    </section>

    {/* CTA Section */}
    <CtaSection
      title="Still have questions?"
      subtitle="Can't find the answer you're looking for? Our team is here to help."
			bgColors="bg-linear-to-br from-secondary via-secondary/80 to-primary"
        primary={{
          label: "Contact Us",
          href: "/contact",
          variant: "solid",
          icon: ArrowRight,
          iconPosition: "right",
          bgColor: "white",
          hoverBgColor: "white/90",
          textColor: "primary",
          hoverTextColor: "primary",
          hoverScale: true
        }}
      />

  </div>
</WebPageLayout>
