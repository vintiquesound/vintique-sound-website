---
// Astro layout and section components
import WebPageLayout from "@/layouts/WebPageLayout.astro";
import HeroSection from "@/layouts/sections/HeroSection.astro";
import ThreeCardsSection from "@/layouts/sections/ThreeCardsSection.astro";
import CtaSection from "@/layouts/sections/CtaSection.astro";

// Third party libraries
import { Headphones, CheckCircle, MessageSquareText, GraduationCap, ArrowRight } from "lucide-astro";

// Local content and assets
import HeroMixerImage from "@/assets/website/audio_mixer-unsplash.jpg";
import { HOME_TITLE, HOME_DESCRIPTION } from "@/consts";
---

<WebPageLayout title={HOME_TITLE} description={HOME_DESCRIPTION}>
	<div class="flex flex-col">
    {/* Hero Section */}
		<HeroSection
      bgColors="bg-linear-to-br from-primary/20 via-secondary/15 to-accent/20"
      title="Professional Mixing and Mastering & More!"
			subtitle="Mixing, mastering, audio repair, tutorials, audio tools, premium plugins, and more — everything you need to create professional-level audio."
      solidButton={{
        label: "Mixing & Mastering",
        href: "/mixing-and-mastering",
        ariaLabel: "Go to Mixing and Mastering services",
        icon: ArrowRight,
        iconPosition: "right",
        hoverScale: true,
      }}
      outlineButton={{
        label: "Check Out My Blog",
        href: "/blog",
        ariaLabel: "Go to the blog",
        hoverBgColor: "white",
        textColor: "foreground",
        borderColor: "foreground",
        hoverScale: true,
      }}
			image={HeroMixerImage}
			imageAlt="Music Studio Audio Mixer"
      imageIsPriority={true}
			imagePosition="right"
		/>

    {/* Services Preview */}
    <ThreeCardsSection
      class="bg-muted"
      title="Most Popular Offerings"
      subtitle="Professional audio solutions for every stage of production."
      cards={[
        {
          title: "Mixing & Mastering",
          subtitle:
            "Professional mixing and mastering that brings clarity, balance, and impact to your music.",
          icon: Headphones,
          colorStyle: "primary",
          bullets: [
            { text: "Industry-standard quality", icon: CheckCircle },
            { text: "Fast turnaround times", icon: CheckCircle },
            { text: "30-day money-back guarantee", icon: CheckCircle },
          ],
          button: {
            label: "Learn More",
            href: "/mixing-and-mastering",
            ariaLabel: "Learn more about Mixing and Mastering services",
            variant: "solid",
            bgColor: "primary",
            textColor: "primary-foreground",
            hoverBgColor: "primary/90",
          },
        },
        {
          title: "Project Feedback",
          subtitle: "Clear, actionable project feedback on what's working, what isn't, and what to change next in your production.",
          icon: MessageSquareText,
          colorStyle: "secondary",
          bullets: [
            { text: "Full review of strengths and issues", icon: CheckCircle },
            { text: "Practical suggestions for improvements", icon: CheckCircle },
            { text: "Recorded, live, and deep dive reviews", icon: CheckCircle },
          ],
          button: {
            label: "Learn More",
            href: "/project-feedback",
            ariaLabel: "Learn more about Project Feedback services",
            variant: "solid",
            bgColor: "secondary",
            textColor: "secondary-foreground",
            hoverBgColor: "secondary/90",
          },
        },
        {
          title: "Educational Blog",
          subtitle:
            "Practical tutorials designed to help you improve your production, mixing, and mastering skills.",
          icon: GraduationCap,
          colorStyle: "accent",
          bullets: [
            { text: "Step-by-step tutorials", icon: CheckCircle },
            { text: "Insightful tips and tricks", icon: CheckCircle },
            { text: "Product reviews", icon: CheckCircle },
          ],
          button: {
            label: "View Blog",
            href: "/blog",
            ariaLabel: "View audio production blog posts",
            variant: "solid",
            bgColor: "accent",
            textColor: "accent-foreground",
            hoverBgColor: "accent/90",
          },
        },
      ]}
    />

    {/* CTA Section */}
    <CtaSection
      bgColors="bg-linear-to-br from-primary via-primary/80 to-secondary"
      title="Ready to Elevate Your Sound?"
      subtitle="Join hundreds of producers and engineers who trust Vintique Sound for their audio needs."
      solid={{
        label: "Get Started Today",
        href: "/mixing-and-mastering",
        ariaLabel: "Get started with Mixing and Mastering services",
        icon: ArrowRight,
        iconPosition: "right",
        bgColor: "white",
        hoverBgColor: "white/90",
        textColor: "primary",
        hoverTextColor: "primary"
      }}
      outline={{
        label: "Contact Me",
        href: "/contact",
        ariaLabel: "Contact Vintique Sound",
        borderAlways: true,
        borderColor: "white",
        hoverBorderColor: "white",
        hoverBgColor: "secondary/60",
        textColor: "white",
        hoverTextColor: "white"
      }}
      />

  </div>
</WebPageLayout>
