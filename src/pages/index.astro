---
import { Headphones, CheckCircle, GraduationCap, Package, ArrowRight } from "lucide-react";
import { Button } from "@/components/ui/button";
import WebPageLayout from "../layouts/WebPageLayout.astro";
import HeroSection from "@/layouts/sections/HeroSection.astro";
import ThreeCardsSection from "@/layouts/sections/ThreeCardsSection.astro";
import CtaSection from "@/layouts/sections/CtaSection.astro";
import HeroMixerImage from "../assets/website/audio_mixer-unsplash.jpg";
---

<WebPageLayout >
	<div class="flex flex-col">
    {/* Hero Section */}
		<HeroSection
			title="Professional Audio Services & More!"
			subtitle="From mixing & mastering, to educational content, to premium plugins, Vintique Sound helps you get professional quality music."
      primary={{ label: "Explore Services", href: "/mixing-mastering", icon: ArrowRight, iconPosition: "right" }}
      outline={{ label: "View Tutorials", href: "/education" }}
			image={HeroMixerImage}
			imageAlt="Music Studio Audio Mixer"
			imagePosition="right"
		/>


    {/* Services Preview */}
    <ThreeCardsSection
      class="bg-muted/50"
      title="Our Services"
      subtitle="Professional audio services tailored to your needs"
      cards={[
        {
          title: "Mixing & Mastering",
          subtitle: "Professional mixing and mastering services to make your tracks shine",
          icon: Headphones,
          accent: "primary",
        },
        {
          title: "Education & Tutorials",
          subtitle: "Learn from industry professionals with our comprehensive tutorials",
          icon: GraduationCap,
          accent: "secondary",
        },
        {
          title: "Digital Products",
          subtitle: "Premium plugins, samples, and loops for your productions",
          icon: Package,
          accent: "accent",
        },
      ]}
    >
      <Fragment slot="card1Content">
        <ul class="space-y-2 mb-6">
          <li class="flex items-center gap-2 text-sm">
            <CheckCircle className="h-4 w-4 text-secondary" />
            <span>Industry-standard quality</span>
          </li>
          <li class="flex items-center gap-2 text-sm">
            <CheckCircle className="h-4 w-4 text-secondary" />
            <span>Fast turnaround times</span>
          </li>
          <li class="flex items-center gap-2 text-sm">
            <CheckCircle className="h-4 w-4 text-secondary" />
            <span>Unlimited revisions</span>
          </li>
        </ul>
      </Fragment>
      <Fragment slot="card1Footer">
        <a href="/services" class="block">
          <Button fullWidth variant="default">Learn More</Button>
        </a>
      </Fragment>

      <Fragment slot="card2Content">
        <ul class="space-y-2 mb-6">
          <li class="flex items-center gap-2 text-sm">
            <CheckCircle className="h-4 w-4 text-secondary" />
            <span>Step-by-step courses</span>
          </li>
          <li class="flex items-center gap-2 text-sm">
            <CheckCircle className="h-4 w-4 text-secondary" />
            <span>Expert instructors</span>
          </li>
          <li class="flex items-center gap-2 text-sm">
            <CheckCircle className="h-4 w-4 text-secondary" />
            <span>Lifetime access</span>
          </li>
        </ul>
      </Fragment>
      <Fragment slot="card2Footer">
        <a href="/education" class="block">
          <Button fullWidth variant="secondary">Browse Courses</Button>
        </a>
      </Fragment>

      <Fragment slot="card3Content">
        <ul class="space-y-2 mb-6">
          <li class="flex items-center gap-2 text-sm">
            <CheckCircle className="h-4 w-4 text-secondary" />
            <span>Professional quality</span>
          </li>
          <li class="flex items-center gap-2 text-sm">
            <CheckCircle className="h-4 w-4 text-secondary" />
            <span>Royalty-free content</span>
          </li>
          <li class="flex items-center gap-2 text-sm">
            <CheckCircle className="h-4 w-4 text-secondary" />
            <span>Instant download</span>
          </li>
        </ul>
      </Fragment>
      <Fragment slot="card3Footer">
        <a href="/products" class="block">
          <Button fullWidth variant="accent">Shop Now</Button>
        </a>
      </Fragment>
    </ThreeCardsSection>

    {/* CTA Section */}
    <CtaSection
      title="Ready to Elevate Your Sound?"
      subtitle="Join hundreds of producers and engineers who trust Vintique Sound for their audio needs"
      colors={["primary", "primary/80", "secondary"]}
      primary={{
        label: "Get Started Today",
        href: "#",
        variant: "secondary",
        icon: ArrowRight,
        iconPosition: "right",
        className: "bg-white text-primary hover:bg-white/90",
      }}
      secondary={{
        label: "Contact Us",
        href: "#",
        variant: "outline",
        className: "border-white text-black hover:bg-white/10",
      }}
    />
  </div>
</WebPageLayout>
