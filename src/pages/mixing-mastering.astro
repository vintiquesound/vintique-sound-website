---
import { Icon } from "astro-icon/components"
import { ArrowRight } from "lucide-astro";
import WebPageLayout from "@/layouts/WebPageLayout.astro";
import IntroSection from "@/layouts/sections/IntroSection.astro";
import CtaSection from "@/layouts/sections/CtaSection.astro";
import Badge from "@/components/ui/Badge.astro";
import Card from "@/components/ui/card/Card.astro";
import CardHeader from "@/components/ui/card/CardHeader.astro";
import CardTitle from "@/components/ui/card/CardTitle.astro";
import CardContent from "@/components/ui/card/CardContent.astro";
import CardDescription from "@/components/ui/card/CardDescription.astro";
import CardAction from "@/components/ui/card/CardAction.astro";
import AudioComparison from "@/components/audio/AudioComparison.tsx";

const services = [
  {
    title: "Mixing",
    description:
      "Transform your individual tracks into a cohesive, balanced, and polished song. Mixing involves level balancing, EQ, compression, spatial placement, and creative effects.",
    features: [
      "Multi-track level balancing",
      "EQ and frequency management",
      "Dynamic processing (compression, limiting)",
      "Spatial placement and depth",
      "Creative effects and automation",
      "Detailed mix referencing and quality checks",
    ],
    price: "from $200",
    color: "primary",
  },
  {
    title: "Mastering",
    description:
      "The final polish that ensures your mixed track sounds professional across all playback systems.",
    features: [
      "Final EQ and tonal balance",
      "Compression and limiting",
      "Loudness optimization (LUFS)",
      "Stereo width enhancement",
      "Multiple format delivery",
      "Platform-specific masters available",
    ],
    price: "from $30",
    color: "secondary",
  },
  {
    title: "Mix + Master Package",
    description:
      "Complete audio production from raw tracks to release-ready masters. You get everything that's included in the mixing and mastering packages.",
    features: [
      "Everything in Mixing",
      "Everything in Mastering",
      "3 mix revisions and 3 mastering revisions included",
      "Mix decisions made with final master in mind",
      "Fewer revisions due to end-to-end consistency",
      "Best overall value for full production",
    ],
    price: "from $220",
    color: "accent",
    badge: "Best Value",
  },
  {
    title: "Stem Mastering",
    description:
      "Master your song using individual stems for more control while maintaining cohesion from an existing mix.",
    features: [
      "Enhanced control over mix elements",
      "Targeted processing per stem",
      "Maintains mix cohesion",
      "Greater flexibility than stereo mastering",
      "Ideal for EDM and hip-hop",
      "Available for up to 12 stems",
    ],
    price: "from $80",
    color: "primary",
  },
];

const idealClients = [
  {
    icon: "lucide:user",
    title: "Independent Artists",
    description:
      "Musicians releasing their own music who want professional-quality results without a label budget",
  },
  {
    icon: "lucide:headphones",
    title: "Music Producers",
    description:
      "Producers who want an experienced engineer's perspective on their productions",
  },
  {
    icon: "lucide:users",
    title: "Bands",
    description:
      "Groups working on EPs, albums, or singles who need consistent, professional sound",
  },
  {
    icon: "lucide:briefcase",
    title: "Studios & Engineers",
    description:
      "Other studios outsourcing mastering or seeking a second opinion on mixes",
  },
  {
    icon: "lucide:video",
    title: "Content Creators",
    description:
      "Podcasters, YouTubers, and media creators who need audio post-production",
  },
];

const processSteps = [
  {
    icon: "lucide:upload",
    title: "Project Upload",
    description:
      "Upload your Cubase, Ableton, or Bitwig project — or consolidated audio files — through my secure transfer system.",
  },
  {
    icon: "lucide:search",
    title: "Initial Review",
    description:
      "I carefully review your files, reference tracks, and notes to fully understand your sound and goals.",
  },
  {
    icon: "lucide:settings",
    title: "Mixing & Mastering",
    description:
      "Your tracks are mixed and/or mastered using professional tools. A high-quality preview is uploaded for feedback.",
  },
  {
    icon: "lucide:rotate-ccw",
    title: "Revisions & Feedback",
    description:
      "You request adjustments, and I refine the mix and/or master until it feels right to you.",
  },
  {
    icon: "lucide:download",
    title: "Final Delivery",
    description:
      "Download your finished files in multiple formats, ready for release.",
  },
];
---

<WebPageLayout title="Contact" description="Reach out to Vintique Sound for audio services, lessons, or questions.">

    {/* INTRO SECTION */}
    <IntroSection
      bgColors="bg-linear-to-br from-primary/20 to-secondary/20"
      badgeText="Mixing & Mastering"
      badgeColor="bg-primary text-primary-foreground"
      title="Professional Mixing & Mastering"
      subtitle="Unlock the full potential of your music with professional mixing and mastering tailored to your genre and vision."
      solidButton={{
        label: "Build Your Package",
        href: "/build-your-package",
        icon: ArrowRight,
        iconPosition: "right"
      }}
      outlineButton={{
        label: "Ask A Question",
        href: "/contact",
        hoverBgColor: "white",
        textColor: "foreground",
        borderColor: "foreground"
      }}
      align="center"
    />

    {/* SERVICES SECTION */}
    <section class="py-20 bg-muted">
      <div class="container mx-auto px-4">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-bold mb-4">
            Mixing & Mastering Services
          </h2>
          <p class="pb-0 mb-0 text-lg text-muted-foreground">
            Clear pricing, flexible options, and professional results
          </p>
          <i class="pt-0 mt-0 text-sm text-muted-foreground">
            *All packages include up to 3 revisions. Unlimited revisions are available as an optional add-on.
          </i>
        </div>

        <div class="grid md:grid-cols-2 gap-8 max-w-6xl mx-auto">
          {services.map((service) => (
            <Card class="border-2 hover:border-primary transition-all relative">
              {service.badge && (
                <CardAction class="absolute -top-3 right-4">
                  <Badge
                    text={service.badge}
                  />
                </CardAction>
              )}
              <CardHeader>
                <CardTitle class="text-3xl">{service.title}</CardTitle>
                <p class="mb-0 text-2xl font-bold text-primary">{service.price}</p>
              </CardHeader>
              <CardContent>
                <CardDescription>{service.description}</CardDescription>
                <ul class="mt-4 space-y-3">
                  {service.features.map((feature) => (
                    <li class="flex gap-2">
                      <Icon name="lucide:check-circle" class="text-secondary h-5 w-5" />
                      <span>{feature}</span>
                    </li>
                  ))}
                </ul>
              </CardContent>
            </Card>
          ))}
        </div>
      </div>
    </section>

    {/* GENRE SPECIALIZATION SECTION */}
    <section class="py-20 bg-linear-to-br from-secondary/20 to-accent/20">
      <div class="container mx-auto px-4 max-w-4xl">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-bold mb-4">
            Genres I Specialize In
          </h2>
          <p class="text-lg text-muted-foreground">
            Experience working across a range of styles while respecting the
            identity of each genre
          </p>
        </div>

        <ul class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
          {[
            "Indie Rock",
            "Classic Rock",
            "Hard Rock",
            "House Music",
          ].map((genre) => (
            <li class="p-6 border rounded-lg font-semibold bg-card">
              {genre}
            </li>
          ))}
        </ul>
      </div>
    </section>

    {/* AUDIO COMPARISON SECTION */}
    <section class="py-20 bg-muted">
      <div class="container mx-auto px-4">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-bold mb-4">
            Hear The Difference
          </h2>
          <p class="pb-0 mb-0 text-lg text-muted-foreground">
            Before and after examples from real mixing and mastering projects
          </p>
          <i class="pt-0 mt-0 text-sm text-muted-foreground">
            *All examples are level-matched for accurate comparison
          </i>
        </div>

        <div class="flex flex-col gap-6 max-w-4xl mx-auto">
          <AudioComparison client:load
            title="Rock / Alternative Mix"
            samples={{
              beforeMix: "/audio/comparisons/scot_helman-21_days-untouched_raw_tracks.mp3",
              beforeMaster: "/audio/comparisons/scot_helman-21_days-untouched_raw_tracks.mp3",
              after: "/audio/comparisons/scot_helman-21_days-mixed_and_mastered.mp3"
            }}
          />
          <AudioComparison client:load
            title="Hip-Hop Mastering"
            samples={{
              beforeMix: "/audio/comparisons/scot_helman-21_days-untouched_raw_tracks.mp3",
              beforeMaster: "/audio/comparisons/scot_helman-21_days-untouched_raw_tracks.mp3",
              after: "/audio/comparisons/scot_helman-21_days-mixed_and_mastered.mp3"
            }}
          />
          <AudioComparison client:load
            title="Electronic / EDM"
            samples={{
              beforeMix: "/audio/comparisons/scot_helman-21_days-untouched_raw_tracks.mp3",
              beforeMaster: "/audio/comparisons/scot_helman-21_days-untouched_raw_tracks.mp3",
              after: "/audio/comparisons/scot_helman-21_days-mixed_and_mastered.mp3"
            }}
          />
        </div>
      </div>
    </section>

    {/* PROCESS SECTION */}
    <section class="py-20">
      <div class="container mx-auto px-4">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-bold mb-4">
            How It Works
          </h2>
          <p class="text-lg text-muted-foreground">
            A simple, collaborative process from upload to final delivery
          </p>
        </div>

        <div class="grid md:grid-cols-5 gap-8 max-w-6xl mx-auto">
          {processSteps.map((step, _i) => (
            <div class="text-center">
              <div class="w-16 h-16 rounded-full bg-linear-to-br from-primary to-secondary flex items-center justify-center mx-auto mb-4">
                  <Icon name={step.icon} class="h-7 w-7 text-white" />
              </div>
              <h3 class="font-bold">{step.title}</h3>
              <p class="text-sm text-muted-foreground">{step.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* WHO ITS FOR SECTION */}
    <section class="py-20 bg-muted">
      <div class="container mx-auto px-4">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-bold mb-4">
            Is This Right for You?
          </h2>
          <p class="text-lg text-muted-foreground">
            These services are designed for artists who care about their sound
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto">
          {idealClients.map((client) => (
            <Card class="border-2">
              <CardHeader class="flex flex-col items-center">
                <Icon name={client.icon} class="h-6 w-6 text-primary mb-3" />
                <CardTitle class="font-bold text-center">{client.title}</CardTitle>
              </CardHeader>
              <CardContent>
                <CardDescription class="text-center">{client.description}</CardDescription>
              </CardContent>
            </Card>
          ))}
        </div>
      </div>
    </section>

    {/* CTA SECTION */}
    <CtaSection
      bgColors="bg-linear-to-br from-primary via-primary/80 to-accent"
      title="Ready to Take Your Music to the Next Level?"
      subtitle="Professional mixing and mastering that competes with industry releases."
      solid={{
        label: "Build Your Package",
        href: "/build-your-package",
        icon: ArrowRight,
        bgColor: "white",
        hoverBgColor: "white",
        textColor: "primary",
        hoverTextColor: "primary",
        iconPosition: "right"
      }}
      outline={{
        label: "Ask a Question",
        href: "/contact",
        borderAlways: true,
        borderColor: "white",
        hoverBorderColor: "white",
        hoverBgColor: "accent/60",
        textColor: "white",
        hoverTextColor: "white"
      }}
    />

</WebPageLayout>

